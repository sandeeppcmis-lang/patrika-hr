<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= title %></title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
  <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css" rel="stylesheet">
  <style>
    :root { --gold: #c9941a; --dark: #1a1a2e; }
    body { background: #f4f6fa; font-family: 'Segoe UI', sans-serif; }
    .page-header {
      background: linear-gradient(135deg, var(--dark), #8b6914);
      color: #fff; padding: 28px 0 22px; margin-bottom: 32px;
    }
    .page-header h1 { color: #f0c030; font-size: 1.6rem; font-weight: 700; margin: 0; }
    .page-header p { color: rgba(255,255,255,.75); margin: 6px 0 0; font-size: .9rem; }
    .card { border: 1px solid #e8dfc5; border-radius: 10px; box-shadow: 0 2px 8px rgba(0,0,0,.06); }
    .card-header-gold {
      background: linear-gradient(135deg, var(--dark), #3a2a00);
      color: #f0c030; font-weight: 600; border-radius: 9px 9px 0 0 !important;
      padding: 14px 20px; font-size: .95rem;
    }
    .card-header-gold i { color: var(--gold); }
    .form-label { font-weight: 600; font-size: .875rem; color: #3a3a3a; }
    .form-control, .form-select { border-color: #d0c89e; font-size: .9rem; }
    .form-control:focus, .form-select:focus { border-color: var(--gold); box-shadow: 0 0 0 .2rem rgba(201,148,26,.2); }
    .btn-gold { background: var(--gold); border-color: var(--gold); color: #fff; font-weight: 600; }
    .btn-gold:hover { background: #a87c15; border-color: #a87c15; color: #fff; }
    .required-star { color: #dc3545; }
    .section-divider { border-color: #e8dfc5; margin: 8px 0 18px; }
    .replacement-section { display: none; }
    .form-check-label { font-size: .875rem; }
    .radio-group .form-check { display: inline-block; margin-right: 20px; }
  </style>
</head>
<body>

<div class="page-header">
  <div class="container">
    <div class="d-flex align-items-center gap-3">
      <img src="/images/patrika-logo.png" alt="Patrika" style="height:48px;border-radius:6px;"
           onerror="this.style.display='none'">
      <div>
        <h1><i class="bi bi-clipboard-check-fill me-2"></i>Manpower Requisition Form</h1>
        <p>Rajasthan Patrika | Patrika Group – HR Department</p>
      </div>
    </div>
  </div>
</div>

<div class="container pb-5" style="max-width:860px;">
  <form action="<%= prefill.token ? '/requisition/fill/' + prefill.token : '/requisition' %>" method="POST" novalidate id="reqForm">

    <!-- Header Card -->
    <div class="card mb-4">
      <div class="card-header-gold"><i class="bi bi-info-circle-fill me-2"></i>Basic Information</div>
      <div class="card-body p-4">
        <div class="row g-3">
          <div class="col-md-6">
            <label class="form-label">Department <span class="required-star">*</span></label>
            <input type="text" name="department" class="form-control" placeholder="e.g. Sales & Marketing" required
                   value="<%= prefill.department || '' %>">
          </div>
          <div class="col-md-6">
            <label class="form-label">Requested By (Name) <span class="required-star">*</span></label>
            <input type="text" name="requestedByName" class="form-control" placeholder="Full Name" required
                   value="<%= prefill.requestedByName || '' %>">
          </div>
          <div class="col-md-4">
            <label class="form-label">Requested Date</label>
            <input type="date" name="requestedDate" class="form-control"
                   value="<%= new Date().toISOString().split('T')[0] %>">
          </div>
        </div>
      </div>
    </div>

    <!-- Vacancy Details Card -->
    <div class="card mb-4">
      <div class="card-header-gold"><i class="bi bi-person-plus-fill me-2"></i>Vacancy Details</div>
      <div class="card-body p-4">
        <div class="row g-3">
          <div class="col-md-8">
            <label class="form-label">Name of the Position <span class="required-star">*</span></label>
            <input type="text" name="positionName" class="form-control" placeholder="e.g. Senior Sales Executive" required>
          </div>
          <div class="col-md-4">
            <label class="form-label">No. of Requirements</label>
            <input type="number" name="noOfRequirements" class="form-control" value="1" min="1" max="50">
          </div>
          <div class="col-md-4">
            <label class="form-label">Present Strength in Dept.</label>
            <input type="number" name="presentStrength" class="form-control" min="0">
          </div>
          <div class="col-12">
            <label class="form-label">Recruitment Type <span class="required-star">*</span></label>
            <div class="radio-group mt-1">
              <div class="form-check">
                <input class="form-check-input" type="radio" name="recruitmentType"
                       id="rtNew" value="New Recruitment" checked>
                <label class="form-check-label" for="rtNew">New Recruitment</label>
              </div>
              <div class="form-check">
                <input class="form-check-input" type="radio" name="recruitmentType"
                       id="rtReplace" value="Replacement">
                <label class="form-check-label" for="rtReplace">Replacement</label>
              </div>
              <div class="form-check">
                <input class="form-check-input" type="radio" name="recruitmentType"
                       id="rtExpand" value="Expansion">
                <label class="form-check-label" for="rtExpand">Expansion</label>
              </div>
            </div>
          </div>
          <div class="col-12">
            <label class="form-label">Why Additional Manpower Required?</label>
            <textarea name="whyRequired" class="form-control" rows="3"
                      placeholder="Briefly explain the business need..."></textarea>
          </div>
          <div class="col-12">
            <label class="form-label">Reason if New Appointment</label>
            <div class="d-flex flex-wrap gap-3 mt-1 align-items-center">
              <div class="form-check">
                <input class="form-check-input" type="checkbox" name="reasonIfNew"
                       id="rWorkload" value="Workload Increased">
                <label class="form-check-label" for="rWorkload">Workload Increased</label>
              </div>
              <div class="form-check">
                <input class="form-check-input" type="checkbox" name="reasonIfNew"
                       id="rExpansion" value="Expansion">
                <label class="form-check-label" for="rExpansion">Expansion</label>
              </div>
              <div class="form-check">
                <input class="form-check-input" type="checkbox" name="reasonIfNew"
                       id="rOthers" value="Others">
                <label class="form-check-label" for="rOthers">Others:</label>
              </div>
              <input type="text" name="reasonIfNewOther" id="reasonIfNewOther"
                     class="form-control" style="width:200px;display:none;"
                     placeholder="Please specify">
            </div>
          </div>
        </div>

        <!-- Replacement Details -->
        <div class="replacement-section mt-3" id="replacementSection">
          <hr class="section-divider">
          <h6 class="text-gold mb-3" style="color:var(--gold);"><i class="bi bi-person-dash me-2"></i>Replacement Details</h6>
          <div class="row g-3">
            <div class="col-md-6">
              <label class="form-label">Name of Person Being Replaced</label>
              <input type="text" name="replacementName" class="form-control" placeholder="Full name">
            </div>
            <div class="col-md-6">
              <label class="form-label">Their Salary (Net/Gross/CTC incl. PLI)</label>
              <input type="text" name="replacementSalary" class="form-control" placeholder="e.g. ₹45,000 CTC">
            </div>
            <div class="col-md-4">
              <label class="form-label">Last Working Date</label>
              <input type="text" name="replacementLastWorking" class="form-control" placeholder="DD/MM/YYYY">
            </div>
          </div>
        </div>
      </div>
    </div>

    <!-- Job Responsibility -->
    <div class="card mb-4">
      <div class="card-header-gold"><i class="bi bi-list-task me-2"></i>Job Responsibility</div>
      <div class="card-body p-4">
        <textarea name="jobResponsibility" class="form-control" rows="5"
                  placeholder="List key responsibilities for this role..."></textarea>
      </div>
    </div>

    <!-- Job Specification -->
    <div class="card mb-4">
      <div class="card-header-gold"><i class="bi bi-person-check-fill me-2"></i>Job Specification</div>
      <div class="card-body p-4">
        <div class="row g-3">
          <div class="col-md-4">
            <label class="form-label">Age</label>
            <input type="text" name="ageSpec" class="form-control" placeholder="e.g. 25-35 years">
          </div>
          <div class="col-md-8">
            <label class="form-label">Qualification</label>
            <input type="text" name="qualificationSpec" class="form-control" placeholder="e.g. MBA / Graduate">
          </div>
          <div class="col-md-4">
            <label class="form-label">Experience</label>
            <input type="text" name="experienceSpec" class="form-control" placeholder="e.g. 3-5 years">
          </div>
          <div class="col-md-4">
            <label class="form-label">Gender</label>
            <select name="genderSpec" class="form-select">
              <option value="">Any</option>
              <option value="Male">Male</option>
              <option value="Female">Female</option>
              <option value="Male / Female">Male / Female</option>
            </select>
          </div>
          <div class="col-md-4">
            <label class="form-label">Other Skills (IT etc.)</label>
            <input type="text" name="otherSkills" class="form-control" placeholder="e.g. MS Office, Tally">
          </div>
          <div class="col-md-6">
            <label class="form-label">Place of Posting</label>
            <input type="text" name="placeOfPosting" class="form-control" placeholder="e.g. Jaipur HO">
          </div>
          <div class="col-md-6">
            <label class="form-label">Salary Range</label>
            <input type="text" name="salaryRange" class="form-control" placeholder="e.g. ₹25,000–₹35,000 CTC">
          </div>
        </div>
      </div>
    </div>

    <!-- Reporting To -->
    <div class="card mb-4">
      <div class="card-header-gold"><i class="bi bi-diagram-3-fill me-2"></i>Reporting Structure</div>
      <div class="card-body p-4">
        <div class="col-md-6">
          <label class="form-label">Reporting To</label>
          <input type="text" name="reportingTo" class="form-control" placeholder="Designation / Name">
        </div>
      </div>
    </div>

    <!-- Referral Card -->
    <div class="card mb-4">
      <div class="card-header-gold"><i class="bi bi-people-fill me-2"></i>Referral (Optional)</div>
      <div class="card-body p-4">
        <p class="text-muted mb-3" style="font-size:.875rem;">Anyone you want to refer for this job?</p>
        <div class="row g-3">
          <div class="col-md-4">
            <label class="form-label">Name</label>
            <input type="text" name="referralName" class="form-control" placeholder="Full name">
          </div>
          <div class="col-md-4">
            <label class="form-label">Mobile</label>
            <input type="tel" name="referralMobile" class="form-control" placeholder="+91 98765 43210">
          </div>
          <div class="col-md-4">
            <label class="form-label">Email</label>
            <input type="email" name="referralEmail" class="form-control" placeholder="email@example.com">
          </div>
        </div>
      </div>
    </div>

    <!-- Submit -->
    <div class="text-center py-2">
      <button type="submit" class="btn btn-gold btn-lg px-5" id="submitBtn">
        <i class="bi bi-send-fill me-2"></i>Submit Requisition
      </button>
    </div>

  </form>
</div>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
<script>
  // Show/hide replacement section
  document.querySelectorAll('input[name="recruitmentType"]').forEach(el => {
    el.addEventListener('change', function () {
      const sec = document.getElementById('replacementSection');
      sec.style.display = this.value === 'Replacement' ? 'block' : 'none';
    });
  });

  // Show "Others" text field
  document.getElementById('rOthers').addEventListener('change', function () {
    document.getElementById('reasonIfNewOther').style.display = this.checked ? 'inline-block' : 'none';
  });

  // Submit loading state
  document.getElementById('reqForm').addEventListener('submit', function (e) {
    const btn = document.getElementById('submitBtn');
    btn.disabled = true;
    btn.innerHTML = '<span class="spinner-border spinner-border-sm me-2"></span>Submitting...';
  });
</script>
</body>
</html>
