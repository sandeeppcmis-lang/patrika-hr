<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= title %></title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
  <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css" rel="stylesheet">
  <link href="/css/style.css?v=<%= v %>" rel="stylesheet">
  <style>
    .pos-row td { vertical-align: middle; }
    .badge-pill { font-size: 11px; font-weight: 500; }
    .jd-preview { font-size: 12px; color: #666; max-height: 40px; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; max-width: 300px; }
    .form-switch .form-check-input { width: 2.5em; cursor: pointer; }
    #jdEditor { font-family: monospace; font-size: 12px; min-height: 300px; }
    .icon-preview { font-size: 1.1rem; }
    .drag-handle { cursor: grab; color: #aaa; }
    .inactive-row { opacity: 0.55; }
  </style>
</head>
<body class="admin-page">

  <!-- TOP NAV -->
  <nav class="li-nav">
    <a href="/admin/dashboard" class="li-nav-brand">
      <div class="li-nav-logo">P</div>
      <span class="li-nav-brand-text d-none d-sm-inline">Patrika HR</span>
    </a>
    <form class="li-nav-search" action="/admin/candidates" method="GET">
      <input type="text" name="search" placeholder="Search candidates..." autocomplete="off">
    </form>
    <div class="li-nav-icons">
      <a href="/admin/dashboard" class="li-nav-icon" title="Dashboard">
        <i class="bi bi-speedometer2"></i><span>Dashboard</span>
      </a>
      <a href="/admin/candidates" class="li-nav-icon" title="Candidates">
        <i class="bi bi-people-fill"></i><span>Candidates</span>
      </a>
      <a href="/admin/positions" class="li-nav-icon active" title="Positions">
        <i class="bi bi-briefcase-fill"></i><span>Positions</span>
      </a>
      <a href="/admin/requisitions" class="li-nav-icon" title="Requisitions">
        <i class="bi bi-clipboard-check-fill"></i><span>Requisitions</span>
      </a>
      <a href="/admin/talent-analyst" class="li-nav-icon" title="AI Analyst">
        <i class="bi bi-robot"></i><span>AI Analyst</span>
      </a>
      <a href="/admin/resume-parser" class="li-nav-icon" title="Parser">
        <i class="bi bi-file-earmark-text"></i><span>Parser</span>
      </a>
      <div class="li-nav-divider"></div>
      <div class="li-nav-admin">
        <button class="li-nav-admin-btn" id="adminDropBtn" onclick="toggleAdminDrop()">
          <div class="li-avatar li-avatar-xs"><%= (adminName||'A').charAt(0).toUpperCase() %></div>
          <span style="font-size:.65rem;margin-top:1px;">Me</span>
        </button>
        <div class="li-nav-admin-dropdown" id="adminDropMenu">
          <div style="padding:10px 16px;font-size:.82rem;color:rgba(0,0,0,0.6);">Signed in as<br><strong style="color:rgba(0,0,0,0.9);"><%= adminName %></strong></div>
          <hr>
          <a href="/admin/logout"><i class="bi bi-box-arrow-right me-2"></i>Logout</a>
        </div>
      </div>
    </div>
  </nav>

  <div class="li-layout">

    <!-- LEFT SIDEBAR -->
    <aside class="li-sidebar-left">
      <div class="li-card">
        <div class="li-card-body" style="text-align:center;padding:20px 16px 12px;">
          <div class="li-avatar mx-auto mb-2" style="width:56px;height:56px;font-size:22px;"><%= (adminName||'A').charAt(0).toUpperCase() %></div>
          <div style="font-weight:700;font-size:.95rem;color:rgba(0,0,0,0.9);"><%= adminName %></div>
          <div style="font-size:.8rem;color:rgba(0,0,0,0.6);">HR Administrator</div>
        </div>
        <hr style="margin:0;border-color:rgba(0,0,0,0.15);">
        <ul class="li-sidebar-nav">
          <li><a href="/admin/dashboard"><i class="bi bi-speedometer2"></i>Dashboard</a></li>
          <li><a href="/admin/candidates"><i class="bi bi-people-fill"></i>Candidates</a></li>
          <li><a href="/admin/positions" class="active"><i class="bi bi-briefcase-fill"></i>Positions</a></li>
          <li><a href="/admin/requisitions"><i class="bi bi-clipboard-check-fill"></i>Requisitions</a></li>
          <li><a href="/admin/talent-analyst"><i class="bi bi-robot"></i>AI Analyst</a></li>
          <li><a href="/admin/resume-parser"><i class="bi bi-file-earmark-text"></i>Resume Parser</a></li>
        </ul>
      </div>
    </aside>

    <main class="li-main">
      <div class="li-page-header">
        <div class="li-page-title"><i class="bi bi-briefcase-fill me-2" style="color:#0a66c2;"></i>Positions & Job Descriptions</div>
        <button class="btn-li-primary" data-bs-toggle="modal" data-bs-target="#addModal">
          <i class="bi bi-plus-lg me-1"></i>Add Position
        </button>
      </div>

      <!-- Stats bar -->
      <div class="row g-3 mb-4">
        <div class="col-auto">
          <div class="stat-card stat-card-gold px-4 py-3" style="border-radius:10px;">
            <div class="stat-value" id="totalCount"><%= positions.length %></div>
            <div class="stat-label">Total Positions</div>
          </div>
        </div>
        <div class="col-auto">
          <div class="stat-card px-4 py-3 bg-white border" style="border-radius:10px;">
            <div class="stat-value text-success" id="activeCount"><%= positions.filter(p=>p.isActive).length %></div>
            <div class="stat-label text-muted">Active</div>
          </div>
        </div>
        <div class="col-auto">
          <div class="stat-card px-4 py-3 bg-white border" style="border-radius:10px;">
            <div class="stat-value text-secondary" id="inactiveCount"><%= positions.filter(p=>!p.isActive).length %></div>
            <div class="stat-label text-muted">Inactive</div>
          </div>
        </div>
      </div>

      <!-- Table -->
      <div class="card shadow-sm">
        <div class="card-body p-0">
          <div class="table-responsive">
            <table class="table table-hover mb-0" id="posTable">
              <thead class="table-light">
                <tr>
                  <th style="width:32px"></th>
                  <th>Position</th>
                  <th>Department</th>
                  <th>Badge</th>
                  <th>Job Description</th>
                  <th class="text-center">Active</th>
                  <th class="text-end">Actions</th>
                </tr>
              </thead>
              <tbody id="posTableBody">
                <% positions.forEach(pos => { %>
                <tr class="pos-row <%= pos.isActive ? '' : 'inactive-row' %>" data-id="<%= pos.id %>">
                  <td class="drag-handle ps-3"><i class="bi bi-grip-vertical"></i></td>
                  <td>
                    <div class="d-flex align-items-center gap-2">
                      <i class="bi bi-<%= pos.icon %> icon-preview text-gold"></i>
                      <div>
                        <div class="fw-semibold"><%= pos.name %></div>
                        <small class="text-muted">Sort: <%= pos.sortOrder %></small>
                      </div>
                    </div>
                  </td>
                  <td><span class="badge bg-light text-dark border badge-pill"><%= pos.department || '—' %></span></td>
                  <td><small class="text-muted"><%= pos.badge || '—' %></small></td>
                  <td>
                    <% if (pos.jdHtml && pos.jdHtml.trim()) { %>
                      <div class="jd-preview"><%- pos.jdHtml.replace(/<[^>]+>/g,'').substring(0,120) %>…</div>
                    <% } else { %>
                      <span class="text-danger small"><i class="bi bi-exclamation-circle me-1"></i>No JD</span>
                    <% } %>
                  </td>
                  <td class="text-center">
                    <div class="form-check form-switch d-flex justify-content-center mb-0">
                      <input class="form-check-input toggle-active" type="checkbox"
                        data-id="<%= pos.id %>" <%= pos.isActive ? 'checked' : '' %>>
                    </div>
                  </td>
                  <td class="text-end pe-3">
                    <button class="btn btn-sm btn-outline-gold edit-btn me-1"
                      data-id="<%= pos.id %>"
                      data-name="<%= pos.name %>"
                      data-dept="<%= pos.department %>"
                      data-icon="<%= pos.icon %>"
                      data-badge="<%= pos.badge %>"
                      data-sort="<%= pos.sortOrder %>"
                      data-jd="<%= encodeURIComponent(pos.jdHtml || '') %>"
                      title="Edit">
                      <i class="bi bi-pencil"></i>
                    </button>
                    <button class="btn btn-sm btn-outline-danger delete-btn"
                      data-id="<%= pos.id %>" data-name="<%= pos.name %>" title="Delete">
                      <i class="bi bi-trash"></i>
                    </button>
                  </td>
                </tr>
                <% }) %>
              </tbody>
            </table>
          </div>
        </div>
      </div>
      <p class="text-muted small mt-2"><i class="bi bi-info-circle me-1"></i>Only <strong>Active</strong> positions appear on the candidate apply form.</p>
    </main>
  </div>

<!-- ── Add Position Modal ──────────────────────────────────────────────── -->
<div class="modal fade" id="addModal" tabindex="-1">
  <div class="modal-dialog modal-xl modal-dialog-scrollable">
    <div class="modal-content">
      <div class="modal-header">
        <h5 class="modal-title fw-bold"><i class="bi bi-plus-circle me-2 text-gold"></i>Add New Position</h5>
        <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
      </div>
      <div class="modal-body">
        <div class="row g-3">
          <div class="col-md-6">
            <label class="form-label fw-semibold">Position Name *</label>
            <input type="text" class="form-control" id="add-name" placeholder="e.g. Sales Head Delhi">
          </div>
          <div class="col-md-3">
            <label class="form-label fw-semibold">Department</label>
            <input type="text" class="form-control" id="add-dept" placeholder="e.g. Sales">
          </div>
          <div class="col-md-2">
            <label class="form-label fw-semibold">Sort Order</label>
            <input type="number" class="form-control" id="add-sort" value="0" min="0">
          </div>
          <div class="col-md-1">
            <label class="form-label fw-semibold">Icon</label>
            <input type="text" class="form-control" id="add-icon" value="briefcase" placeholder="briefcase">
            <small class="text-muted">Bootstrap icon name</small>
          </div>
          <div class="col-12">
            <label class="form-label fw-semibold">Badge Text</label>
            <input type="text" class="form-control" id="add-badge" placeholder="e.g. Jaipur · Full-Time · 5+ Yrs">
          </div>
          <div class="col-12">
            <label class="form-label fw-semibold">Job Description (HTML)</label>
            <div class="d-flex gap-2 mb-1">
              <button class="btn btn-sm btn-outline-secondary" onclick="insertJdTemplate('add')">Insert Template</button>
              <button class="btn btn-sm btn-outline-secondary" onclick="previewJd('add')">Preview</button>
            </div>
            <textarea class="form-control" id="add-jd" rows="12" style="font-family:monospace;font-size:12px;" placeholder="Paste HTML job description here..."></textarea>
          </div>
          <div class="col-12" id="add-preview-area" style="display:none;">
            <label class="form-label fw-semibold text-muted">Preview</label>
            <div class="border rounded p-3 bg-light" id="add-preview-content"></div>
          </div>
        </div>
      </div>
      <div class="modal-footer">
        <button class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
        <button class="btn btn-gold" id="addSaveBtn"><i class="bi bi-check-lg me-1"></i>Add Position</button>
      </div>
    </div>
  </div>
</div>

<!-- ── Edit Position Modal ──────────────────────────────────────────────── -->
<div class="modal fade" id="editModal" tabindex="-1">
  <div class="modal-dialog modal-xl modal-dialog-scrollable">
    <div class="modal-content">
      <div class="modal-header">
        <h5 class="modal-title fw-bold"><i class="bi bi-pencil me-2 text-gold"></i>Edit Position</h5>
        <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
      </div>
      <div class="modal-body">
        <input type="hidden" id="edit-id">
        <div class="row g-3">
          <div class="col-md-6">
            <label class="form-label fw-semibold">Position Name *</label>
            <input type="text" class="form-control" id="edit-name">
          </div>
          <div class="col-md-3">
            <label class="form-label fw-semibold">Department</label>
            <input type="text" class="form-control" id="edit-dept">
          </div>
          <div class="col-md-2">
            <label class="form-label fw-semibold">Sort Order</label>
            <input type="number" class="form-control" id="edit-sort" min="0">
          </div>
          <div class="col-md-1">
            <label class="form-label fw-semibold">Icon</label>
            <input type="text" class="form-control" id="edit-icon">
            <small class="text-muted">Bootstrap icon name</small>
          </div>
          <div class="col-12">
            <label class="form-label fw-semibold">Badge Text</label>
            <input type="text" class="form-control" id="edit-badge">
          </div>
          <div class="col-12">
            <label class="form-label fw-semibold">Job Description (HTML)</label>
            <div class="d-flex gap-2 mb-1">
              <button class="btn btn-sm btn-outline-secondary" onclick="insertJdTemplate('edit')">Insert Template</button>
              <button class="btn btn-sm btn-outline-secondary" onclick="previewJd('edit')">Preview</button>
            </div>
            <textarea class="form-control" id="edit-jd" rows="14" style="font-family:monospace;font-size:12px;"></textarea>
          </div>
          <div class="col-12" id="edit-preview-area" style="display:none;">
            <label class="form-label fw-semibold text-muted">Preview</label>
            <div class="border rounded p-3 bg-light" id="edit-preview-content"></div>
          </div>
        </div>
      </div>
      <div class="modal-footer">
        <button class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
        <button class="btn btn-gold" id="editSaveBtn"><i class="bi bi-check-lg me-1"></i>Save Changes</button>
      </div>
    </div>
  </div>
</div>

<!-- ── Delete Confirm Modal ──────────────────────────────────────────────── -->
<div class="modal fade" id="deleteModal" tabindex="-1">
  <div class="modal-dialog">
    <div class="modal-content">
      <div class="modal-header">
        <h5 class="modal-title text-danger"><i class="bi bi-trash me-2"></i>Delete Position</h5>
        <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
      </div>
      <div class="modal-body">
        Are you sure you want to delete <strong id="delete-name"></strong>? This cannot be undone.
      </div>
      <div class="modal-footer">
        <button class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
        <button class="btn btn-danger" id="deleteConfirmBtn">Delete</button>
      </div>
    </div>
  </div>
</div>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
<script>
function toggleAdminDrop() {
  document.getElementById('adminDropMenu').classList.toggle('show');
}
document.addEventListener('click', function(e) {
  if (!e.target.closest('.li-nav-admin')) {
    document.getElementById('adminDropMenu').classList.remove('show');
  }
});

const JD_TEMPLATE = `<div class="mb-3"><h6 class="fw-bold text-gold mb-1">Role Overview</h6>
  <p class="mb-0">Brief description of the role...</p></div>
<div class="mb-3"><h6 class="fw-bold text-gold mb-1">Key Responsibilities</h6>
  <ul class="mb-0 ps-3">
    <li>Responsibility one</li>
    <li>Responsibility two</li>
  </ul></div>
<div class="mb-0"><h6 class="fw-bold text-gold mb-1">Requirements</h6>
  <ul class="mb-0 ps-3">
    <li>Requirement one</li>
    <li>Requirement two</li>
  </ul></div>`;

function insertJdTemplate(mode) {
  const el = document.getElementById(mode + '-jd');
  if (!el.value.trim()) el.value = JD_TEMPLATE;
}

function previewJd(mode) {
  const html = document.getElementById(mode + '-jd').value;
  const area = document.getElementById(mode + '-preview-area');
  const content = document.getElementById(mode + '-preview-content');
  content.innerHTML = html;
  area.style.display = html.trim() ? 'block' : 'none';
}

// ── Toggle active ──────────────────────────────────────────────────────────
document.querySelectorAll('.toggle-active').forEach(el => {
  el.addEventListener('change', async function() {
    const id = this.dataset.id;
    const row = document.querySelector(`tr[data-id="${id}"]`);
    try {
      const r = await fetch(`/admin/positions/${id}/toggle`, { method: 'POST' });
      const d = await r.json();
      if (d.success) {
        row.classList.toggle('inactive-row', !d.isActive);
        updateCounts();
      } else {
        this.checked = !this.checked;
        alert(d.error || 'Failed to toggle');
      }
    } catch(e) { this.checked = !this.checked; alert('Network error'); }
  });
});

function updateCounts() {
  const checks = document.querySelectorAll('.toggle-active');
  const active = [...checks].filter(c => c.checked).length;
  document.getElementById('activeCount').textContent = active;
  document.getElementById('inactiveCount').textContent = checks.length - active;
  document.getElementById('totalCount').textContent = checks.length;
}

// ── Edit ──────────────────────────────────────────────────────────────────────
document.querySelectorAll('.edit-btn').forEach(btn => {
  btn.addEventListener('click', function() {
    document.getElementById('edit-id').value    = this.dataset.id;
    document.getElementById('edit-name').value  = this.dataset.name;
    document.getElementById('edit-dept').value  = this.dataset.dept;
    document.getElementById('edit-icon').value  = this.dataset.icon;
    document.getElementById('edit-badge').value = this.dataset.badge;
    document.getElementById('edit-sort').value  = this.dataset.sort;
    document.getElementById('edit-jd').value    = decodeURIComponent(this.dataset.jd);
    document.getElementById('edit-preview-area').style.display = 'none';
    new bootstrap.Modal(document.getElementById('editModal')).show();
  });
});

document.getElementById('editSaveBtn').addEventListener('click', async function() {
  const id   = document.getElementById('edit-id').value;
  const body = {
    name:       document.getElementById('edit-name').value.trim(),
    department: document.getElementById('edit-dept').value.trim(),
    icon:       document.getElementById('edit-icon').value.trim() || 'briefcase',
    badge:      document.getElementById('edit-badge').value.trim(),
    jdHtml:     document.getElementById('edit-jd').value,
    sortOrder:  document.getElementById('edit-sort').value
  };
  if (!body.name) return alert('Position name is required');
  this.disabled = true;
  try {
    const r = await fetch(`/admin/positions/${id}`, {
      method: 'PUT',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify(body)
    });
    const d = await r.json();
    if (d.success) {
      bootstrap.Modal.getInstance(document.getElementById('editModal')).hide();
      location.reload();
    } else { alert(d.error || 'Failed to save'); }
  } catch(e) { alert('Network error'); }
  this.disabled = false;
});

// ── Add ──────────────────────────────────────────────────────────────────────
document.getElementById('addSaveBtn').addEventListener('click', async function() {
  const body = {
    name:       document.getElementById('add-name').value.trim(),
    department: document.getElementById('add-dept').value.trim(),
    icon:       document.getElementById('add-icon').value.trim() || 'briefcase',
    badge:      document.getElementById('add-badge').value.trim(),
    jdHtml:     document.getElementById('add-jd').value,
    sortOrder:  document.getElementById('add-sort').value
  };
  if (!body.name) return alert('Position name is required');
  this.disabled = true;
  try {
    const r = await fetch('/admin/positions', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify(body)
    });
    const d = await r.json();
    if (d.success) {
      bootstrap.Modal.getInstance(document.getElementById('addModal')).hide();
      location.reload();
    } else { alert(d.error || 'Failed to add'); }
  } catch(e) { alert('Network error'); }
  this.disabled = false;
});

// ── Delete ──────────────────────────────────────────────────────────────────
let deleteId = null;
document.querySelectorAll('.delete-btn').forEach(btn => {
  btn.addEventListener('click', function() {
    deleteId = this.dataset.id;
    document.getElementById('delete-name').textContent = this.dataset.name;
    new bootstrap.Modal(document.getElementById('deleteModal')).show();
  });
});

document.getElementById('deleteConfirmBtn').addEventListener('click', async function() {
  if (!deleteId) return;
  this.disabled = true;
  try {
    const r = await fetch(`/admin/positions/${deleteId}`, { method: 'DELETE' });
    const d = await r.json();
    if (d.success) {
      bootstrap.Modal.getInstance(document.getElementById('deleteModal')).hide();
      document.querySelector(`tr[data-id="${deleteId}"]`).remove();
      updateCounts();
    } else { alert(d.error || 'Failed to delete'); }
  } catch(e) { alert('Network error'); }
  this.disabled = false;
  deleteId = null;
});
</script>
</body>
</html>
