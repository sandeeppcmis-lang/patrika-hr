<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= title %></title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
  <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css" rel="stylesheet">
  <link href="/css/style.css?v=<%= v %>" rel="stylesheet">
  <style>
    /* ── Timeline rail ── */
    .tl-rail { position: relative; padding-left: 48px; }
    .tl-rail::before {
      content: '';
      position: absolute;
      left: 20px;
      top: 0;
      bottom: 0;
      width: 2px;
      background: linear-gradient(to bottom, #f0c030 0%, #2d2d2d 100%);
    }

    /* ── Event card ── */
    .tl-event { position: relative; margin-bottom: 24px; }
    .tl-icon {
      position: absolute;
      left: -40px;
      top: 4px;
      width: 34px;
      height: 34px;
      border-radius: 50%;
      display: flex;
      align-items: center;
      justify-content: center;
      font-size: 15px;
      color: #fff;
      z-index: 1;
      box-shadow: 0 0 0 3px var(--bs-body-bg, #fff);
    }
    .tl-card {
      border-left: 3px solid;
      border-radius: 8px;
      background: #1e1e2e;
      padding: 14px 16px;
      box-shadow: 0 1px 4px rgba(0,0,0,.35);
    }
    .tl-card .tl-title { font-weight: 600; font-size: .95rem; }
    .tl-card .tl-time  { font-size: .78rem; color: #9ca3af; }
    .tl-card .tl-body  { font-size: .875rem; color: #d1d5db; margin-top: 6px; }
    .tl-card .tl-by    { font-size: .78rem; color: #6c757d; margin-top: 4px; }

    /* ── Colour helpers ── */
    .bc-gold    { border-color: #f0c030 !important; }
    .bc-primary { border-color: #0d6efd !important; }
    .bc-success { border-color: #198754 !important; }
    .bc-warning { border-color: #ffc107 !important; }
    .bc-teal    { border-color: #20c997 !important; }
    .bc-purple  { border-color: #6f42c1 !important; }
    .bc-info    { border-color: #0dcaf0 !important; }
    .bc-secondary { border-color: #6c757d !important; }

    .bg-teal   { background-color: #20c997 !important; }
    .bg-purple { background-color: #6f42c1 !important; }
    .text-teal { color: #20c997 !important; }
    .text-gold { color: #f0c030 !important; }

    /* ── Summary card ── */
    .summary-card { position: sticky; top: 24px; }
    .stat-pill {
      display: flex;
      justify-content: space-between;
      align-items: center;
      padding: 8px 14px;
      border-radius: 8px;
      background: rgba(255,255,255,.05);
      margin-bottom: 8px;
      font-size: .875rem;
    }
    .stat-pill .sp-val { font-weight: 700; font-size: 1rem; }

    /* ── Interview summary grid ── */
    .iv-round-card {
      border: 1px solid rgba(255,255,255,.1);
      border-radius: 8px;
      padding: 12px 14px;
      background: rgba(255,255,255,.04);
    }
    .iv-round-card .round-label { font-size: .78rem; text-transform: uppercase; letter-spacing: .05em; color: #9ca3af; }
    .iv-round-card .round-score { font-size: 1.4rem; font-weight: 700; color: #f0c030; }

    /* ── Show-more text ── */
    .truncated-text .full-text  { display: none; }
    .truncated-text.expanded .short-text { display: none; }
    .truncated-text.expanded .full-text  { display: inline; }
    .show-more-btn { font-size: .78rem; cursor: pointer; }

    /* ── Print styles ── */
    @media print {
      .admin-sidebar, .admin-topbar, .no-print, .timeline-email-panel { display: none !important; }
      .admin-main { margin-left: 0 !important; padding: 0 !important; }
      .summary-card { position: static !important; }
      .tl-card { background: #fff !important; color: #000 !important; box-shadow: none; border-left-width: 4px; }
      .tl-card .tl-body { color: #222 !important; }
      .tl-card .tl-time, .tl-card .tl-by { color: #555 !important; }
      .tl-rail::before { background: #ccc; }
      .truncated-text .full-text { display: inline !important; }
      .truncated-text .short-text { display: none !important; }
      .page-break-before { page-break-before: always; }
      body, .admin-wrapper { background: #fff !important; }
      .iv-round-card { background: #f9f9f9 !important; border-color: #ddd !important; }
    }
  </style>
</head>
<body class="admin-page">
<div class="admin-wrapper">

  <!-- ── Sidebar ── -->
  <nav class="admin-sidebar d-flex flex-column">
    <div class="sidebar-brand">
      <img src="/images/patrika-logo.png" alt="Patrika" class="sidebar-logo" onerror="this.style.display='none'">
      <div>
        <div class="fw-bold text-gold">Patrika HR</div>
        <small class="text-white-50">Admin Panel</small>
      </div>
    </div>
    <hr class="border-secondary my-2">
    <ul class="nav flex-column px-2 flex-grow-1">
      <li class="nav-item">
        <a class="nav-link sidebar-link" href="/admin/dashboard">
          <i class="bi bi-speedometer2 me-2"></i>Dashboard
        </a>
      </li>
      <li class="nav-item">
        <a class="nav-link sidebar-link" href="/admin/candidates">
          <i class="bi bi-people-fill me-2"></i>Candidates
        </a>
      </li>
      <li class="nav-item">
        <a class="nav-link sidebar-link" href="/admin/positions">
          <i class="bi bi-briefcase-fill me-2"></i>Positions
        </a>
      </li>
      <li class="nav-item">
        <a class="nav-link sidebar-link" href="/admin/requisitions">
          <i class="bi bi-clipboard-check-fill me-2"></i>Requisitions
        </a>
      </li>
      <li class="nav-item">
        <a class="nav-link sidebar-link" href="/admin/talent-analyst">
          <i class="bi bi-robot me-2"></i>Talent Analyst
        </a>
      </li>
      <li class="nav-item">
        <a class="nav-link sidebar-link" href="/admin/resume-parser">
          <i class="bi bi-file-earmark-text me-2"></i>Resume Parser
        </a>
      </li>
      <li class="nav-item">
        <a class="nav-link sidebar-link" href="/apply" target="_blank">
          <i class="bi bi-file-earmark-person me-2"></i>Application Form
        </a>
      </li>
    </ul>
    <div class="px-2 pb-3">
      <a href="/admin/logout" class="btn btn-outline-light btn-sm w-100">
        <i class="bi bi-box-arrow-right me-1"></i>Logout
      </a>
      <p class="text-white-50 text-center mt-2 mb-0" style="font-size:11px;">
        Logged in as <strong><%= adminName %></strong>
      </p>
    </div>
  </nav>

  <!-- ── Main ── -->
  <main class="admin-main">

    <!-- Topbar -->
    <div class="admin-topbar d-flex align-items-center justify-content-between no-print">
      <div class="d-flex align-items-center gap-3">
        <a href="/admin/candidate/<%= candidate.id %>" class="btn btn-sm btn-outline-secondary">
          <i class="bi bi-arrow-left me-1"></i>Back to Candidate
        </a>
        <div>
          <h6 class="mb-0 fw-bold"><i class="bi bi-clock-history me-2 text-gold"></i>Activity History</h6>
          <small class="text-muted"><%= candidate.fullName %></small>
        </div>
      </div>
      <div class="d-flex gap-2">
        <button class="btn btn-sm btn-outline-secondary" onclick="window.print()">
          <i class="bi bi-printer me-1"></i>Print / PDF
        </button>
      </div>
    </div>

    <div class="p-4">
      <div class="row g-4">

        <!-- ══ LEFT: Timeline ══ -->
        <div class="col-lg-8">

          <% if (events.length === 0) { %>
          <div class="text-center text-muted py-5">
            <i class="bi bi-clock-history" style="font-size:3rem;opacity:.3;"></i>
            <p class="mt-3">No activity recorded yet for this candidate.</p>
          </div>
          <% } else { %>

          <div class="tl-rail">

            <% events.forEach(function(ev) {
              var borderClass = 'bc-secondary';
              if (ev.colorClass === 'gold')      borderClass = 'bc-gold';
              else if (ev.colorClass === 'primary')   borderClass = 'bc-primary';
              else if (ev.colorClass === 'success')   borderClass = 'bc-success';
              else if (ev.colorClass === 'warning')   borderClass = 'bc-warning';
              else if (ev.colorClass === 'teal')      borderClass = 'bc-teal';
              else if (ev.colorClass === 'purple')    borderClass = 'bc-purple';
              else if (ev.colorClass === 'info')      borderClass = 'bc-info';

              var bgClass = 'bg-secondary';
              if (ev.colorClass === 'gold')      bgClass = '';
              else if (ev.colorClass === 'primary')   bgClass = 'bg-primary';
              else if (ev.colorClass === 'success')   bgClass = 'bg-success';
              else if (ev.colorClass === 'warning')   bgClass = 'bg-warning';
              else if (ev.colorClass === 'teal')      bgClass = 'bg-teal';
              else if (ev.colorClass === 'purple')    bgClass = 'bg-purple';
              else if (ev.colorClass === 'info')      bgClass = 'bg-info';
            %>

            <div class="tl-event">
              <div class="tl-icon <%= bgClass %>" style="<%= ev.colorClass === 'gold' ? 'background:#c9941a;' : '' %>">
                <i class="bi <%= ev.icon %>"></i>
              </div>

              <div class="tl-card <%= borderClass %>">
                <div class="d-flex justify-content-between align-items-start flex-wrap gap-1">
                  <span class="tl-title" style="color:<%= ev.color || '#fff' %>;">
                    <% if (ev.type === 'status_changed') { %>
                      Status &rarr; <span class="badge bg-primary ms-1"><%= ev.meta && ev.meta.newValue ? ev.meta.newValue : '' %></span>
                    <% } else { %>
                      <%= ev.title %>
                    <% } %>
                  </span>
                  <span class="tl-time"><i class="bi bi-clock me-1"></i><%= fmtDate(ev.timestamp) %></span>
                </div>

                <% if (ev.type === 'application_received') { %>
                <div class="tl-body">
                  <div class="row g-2 mt-1">
                    <div class="col-sm-6"><small class="text-muted d-block">Position</small><span><%= ev.meta.position %></span></div>
                    <div class="col-sm-6"><small class="text-muted d-block">Package</small><span><%= ev.meta.package %></span></div>
                    <div class="col-sm-6"><small class="text-muted d-block">Notice Period</small><span><%= ev.meta.noticePeriod %></span></div>
                    <div class="col-sm-6"><small class="text-muted d-block">Submitted</small><span><%= ev.meta.submittedAt %></span></div>
                  </div>
                </div>

                <% } else if (ev.type === 'status_changed') { %>
                <div class="tl-body">
                  <span class="badge bg-secondary me-1"><%= ev.meta && ev.meta.oldValue ? ev.meta.oldValue : '—' %></span>
                  <i class="bi bi-arrow-right mx-1 text-muted"></i>
                  <span class="badge bg-primary"><%= ev.meta && ev.meta.newValue ? ev.meta.newValue : '—' %></span>
                </div>

                <% } else if (ev.type === 'note_saved') { %>
                <% var noteText = ev.body || ''; %>
                <div class="tl-body">
                  <% if (noteText.length > 200) { %>
                  <span class="truncated-text" id="note-<%= ev.timestamp.getTime() %>">
                    <span class="short-text"><%= noteText.substring(0, 200) %>&hellip;</span>
                    <span class="full-text"><%= noteText %></span>
                    <a class="show-more-btn text-warning ms-1" onclick="toggleNote('note-<%= ev.timestamp.getTime() %>', this)">Show more</a>
                  </span>
                  <% } else { %>
                  <%= noteText %>
                  <% } %>
                </div>

                <% } else if (ev.type === 'email_sent') { %>
                <div class="tl-body">
                  <% if (ev.meta && ev.meta.subject) { %><div class="fw-semibold mb-1"><i class="bi bi-envelope me-1"></i><%= ev.meta.subject %></div><% } %>
                  <div class="text-muted" style="white-space:pre-line;"><%= ev.body %></div>
                  <% if (ev.meta && ev.meta.status) { %><div class="mt-1"><span class="badge <%= ev.meta.status === 'Sent' ? 'bg-success' : 'bg-danger' %>"><%= ev.meta.status %></span></div><% } %>
                </div>

                <% } else if (ev.type === 'whatsapp_sent') { %>
                <div class="tl-body">
                  <div class="text-muted" style="white-space:pre-line;"><%= ev.body %></div>
                </div>

                <% } else { %>
                <div class="tl-body" style="white-space:pre-line;"><%= ev.body || '' %></div>
                <% } %>

                <div class="tl-by"><i class="bi bi-person me-1"></i><%= ev.performedBy || 'System' %></div>
              </div>
            </div>

            <% }); %>
          </div>

          <% } %>

          <!-- ── Interview Summary Section ── -->
          <% if (interviewSheet) { %>
          <div class="card shadow-sm mt-4 page-break-before">
            <div class="card-header d-flex align-items-center gap-2">
              <i class="bi bi-camera-video-fill text-purple"></i>
              <h6 class="mb-0">Interview Summary</h6>
            </div>
            <div class="card-body">
              <!-- Rounds grid -->
              <div class="row g-3 mb-4">
                <% var rounds = [
                  { label: 'Preliminary', by: interviewSheet.prelimInterviewedBy, date: interviewSheet.prelimDate, marks: null, feedback: interviewSheet.prelimFamilyNotes, rec: null },
                  { label: 'Round 1',     by: interviewSheet.r1InterviewedBy,     date: interviewSheet.r1Date,     marks: interviewSheet.r1Marks, feedback: interviewSheet.r1Feedback, rec: interviewSheet.r1Recommendation },
                  { label: 'Round 2',     by: interviewSheet.r2InterviewedBy,     date: interviewSheet.r2Date,     marks: interviewSheet.r2Marks, feedback: interviewSheet.r2Feedback, rec: interviewSheet.r2Recommendation },
                  { label: 'HR Round',    by: interviewSheet.hrInterviewedBy,     date: interviewSheet.hrDate,     marks: interviewSheet.hrMarks, feedback: interviewSheet.hrFeedback, rec: interviewSheet.hrRecommendation }
                ]; %>
                <% rounds.forEach(function(r) { %>
                <div class="col-md-6">
                  <div class="iv-round-card">
                    <div class="round-label"><%= r.label %></div>
                    <% if (r.by) { %>
                    <div class="mt-2 d-flex justify-content-between align-items-start">
                      <div>
                        <div class="fw-semibold small"><%= r.by %></div>
                        <div class="text-muted" style="font-size:.8rem;"><%= r.date || '—' %></div>
                        <% if (r.rec) { %><div class="mt-1"><span class="badge bg-secondary" style="font-size:.75rem;"><%= r.rec %></span></div><% } %>
                        <% if (r.feedback) { %><div class="text-muted mt-1" style="font-size:.8rem;"><%= r.feedback.substring(0,120) %><%= r.feedback.length > 120 ? '…' : '' %></div><% } %>
                      </div>
                      <% if (r.marks != null) { %>
                      <div class="text-end">
                        <div class="round-score"><%= r.marks %></div>
                        <div style="font-size:.72rem;color:#9ca3af;">/ 100</div>
                      </div>
                      <% } %>
                    </div>
                    <% } else { %>
                    <div class="text-muted mt-2" style="font-size:.85rem;">Not conducted</div>
                    <% } %>
                  </div>
                </div>
                <% }); %>
              </div>

              <!-- Final offer -->
              <div class="row g-3">
                <div class="col-12">
                  <div class="card" style="background:rgba(240,192,48,.08);border-color:rgba(240,192,48,.2);">
                    <div class="card-header py-2" style="background:rgba(240,192,48,.15);border-color:rgba(240,192,48,.2);">
                      <small class="fw-semibold text-gold text-uppercase" style="letter-spacing:.05em;">Final Offer Details</small>
                    </div>
                    <div class="card-body py-3">
                      <div class="row g-2" style="font-size:.875rem;">
                        <div class="col-sm-3 col-6"><span class="text-muted d-block" style="font-size:.78rem;">Salary Offered</span><strong><%= interviewSheet.salaryOffered || '—' %></strong></div>
                        <div class="col-sm-3 col-6"><span class="text-muted d-block" style="font-size:.78rem;">Reporting To</span><strong><%= interviewSheet.reportingTo || '—' %></strong></div>
                        <div class="col-sm-3 col-6"><span class="text-muted d-block" style="font-size:.78rem;">Joining Period</span><strong><%= interviewSheet.joiningPeriod || '—' %></strong></div>
                        <div class="col-sm-3 col-6"><span class="text-muted d-block" style="font-size:.78rem;">Exit Clause</span><strong><%= interviewSheet.exitClause || '—' %></strong></div>
                        <div class="col-sm-3 col-6"><span class="text-muted d-block" style="font-size:.78rem;">Nature</span><strong><%= interviewSheet.natureOfAppointment || '—' %></strong></div>
                        <div class="col-sm-3 col-6"><span class="text-muted d-block" style="font-size:.78rem;">Probation</span><strong><%= interviewSheet.probationPeriod || '—' %></strong></div>
                        <div class="col-sm-3 col-6"><span class="text-muted d-block" style="font-size:.78rem;">Overall Score</span><strong class="text-gold"><%= interviewSheet.overallScore != null ? interviewSheet.overallScore + '/100' : '—' %></strong></div>
                        <div class="col-sm-3 col-6"><span class="text-muted d-block" style="font-size:.78rem;">Final Decision</span>
                          <span class="badge <%=
                            interviewSheet.finalDecision === 'Selected' ? 'bg-success' :
                            interviewSheet.finalDecision === 'Rejected' ? 'bg-danger'  :
                            interviewSheet.finalDecision === 'On Hold'  ? 'bg-warning text-dark' :
                            'bg-secondary'
                          %>"><%= interviewSheet.finalDecision || '—' %></span>
                        </div>
                      </div>
                      <% if (interviewSheet.finalRemarks) { %>
                      <div class="mt-3 pt-2 border-top" style="border-color:rgba(255,255,255,.1)!important;">
                        <small class="text-muted">Remarks:</small>
                        <p class="mb-0 mt-1" style="font-size:.875rem;"><%= interviewSheet.finalRemarks %></p>
                      </div>
                      <% } %>
                    </div>
                  </div>
                </div>
              </div>
            </div>
          </div>
          <% } %>

        </div><!-- /col-lg-8 -->

        <!-- ══ RIGHT: Sticky Summary ══ -->
        <div class="col-lg-4">
          <div class="summary-card">

            <!-- Candidate summary card -->
            <div class="card shadow-sm mb-3">
              <div class="card-header py-2">
                <small class="fw-semibold text-uppercase text-gold" style="letter-spacing:.05em;">Candidate Summary</small>
              </div>
              <div class="card-body">
                <div class="d-flex align-items-center gap-3 mb-3">
                  <div class="avatar-circle avatar-lg"><%= candidate.fullName.charAt(0).toUpperCase() %></div>
                  <div>
                    <div class="fw-bold"><%= candidate.fullName %></div>
                    <div class="text-muted" style="font-size:.83rem;"><%= candidate.positionApplying || '—' %></div>
                  </div>
                </div>
                <div class="mb-2">
                  <small class="text-muted d-block">Current Status</small>
                  <span class="badge bg-primary fs-6 mt-1"><%= candidate.status || '—' %></span>
                </div>
                <% if (interviewSheet && interviewSheet.overallScore != null) { %>
                <div class="mb-2">
                  <small class="text-muted d-block">Overall Interview Score</small>
                  <span class="fw-bold text-gold fs-5"><%= interviewSheet.overallScore %><small class="text-muted fs-6">/100</small></span>
                </div>
                <% } %>
                <div class="mb-1">
                  <small class="text-muted d-block">Applied On</small>
                  <span style="font-size:.875rem;"><%= fmtDate(candidate.submittedAt) %></span>
                </div>
              </div>
            </div>

            <!-- Quick stats -->
            <div class="card shadow-sm mb-3">
              <div class="card-header py-2">
                <small class="fw-semibold text-uppercase text-gold" style="letter-spacing:.05em;">Quick Stats</small>
              </div>
              <div class="card-body py-2">
                <div class="stat-pill">
                  <span><i class="bi bi-envelope-fill text-success me-2"></i>Emails sent</span>
                  <span class="sp-val text-success"><%= stats.emailCount %></span>
                </div>
                <div class="stat-pill">
                  <span><i class="bi bi-whatsapp text-teal me-2"></i>WhatsApp sent</span>
                  <span class="sp-val text-teal"><%= stats.whatsappCount %></span>
                </div>
                <div class="stat-pill">
                  <span><i class="bi bi-arrow-repeat text-primary me-2"></i>Status changes</span>
                  <span class="sp-val text-primary"><%= stats.statusChanges %></span>
                </div>
                <div class="stat-pill">
                  <span><i class="bi bi-camera-video-fill" style="color:#6f42c1;margin-right:8px;"></i>Interview rounds</span>
                  <span class="sp-val" style="color:#6f42c1;"><%= stats.interviewRounds %></span>
                </div>
                <div class="stat-pill">
                  <span><i class="bi bi-sticky-fill text-warning me-2"></i>Notes saved</span>
                  <span class="sp-val text-warning"><%= stats.noteCount %></span>
                </div>
                <div class="stat-pill">
                  <span><i class="bi bi-activity text-muted me-2"></i>Total events</span>
                  <span class="sp-val"><%= events.length %></span>
                </div>
              </div>
            </div>

            <!-- Actions -->
            <div class="card shadow-sm mb-3 no-print">
              <div class="card-header py-2">
                <small class="fw-semibold text-uppercase text-gold" style="letter-spacing:.05em;">Actions</small>
              </div>
              <div class="card-body d-grid gap-2">
                <button class="btn btn-outline-light btn-sm" onclick="window.print()">
                  <i class="bi bi-printer me-2"></i>Download / Print PDF
                </button>
                <a href="/admin/candidate/<%= candidate.id %>" class="btn btn-outline-secondary btn-sm">
                  <i class="bi bi-person-fill me-2"></i>View Candidate Profile
                </a>
                <a href="/admin/candidate/<%= candidate.id %>/interview" class="btn btn-outline-info btn-sm">
                  <i class="bi bi-clipboard-check me-2"></i>Open Interview Sheet
                </a>
              </div>
            </div>

            <!-- Email timeline panel -->
            <div class="card shadow-sm timeline-email-panel no-print">
              <div class="card-header py-2">
                <small class="fw-semibold text-uppercase text-gold" style="letter-spacing:.05em;"><i class="bi bi-envelope me-1"></i>Email this History</small>
              </div>
              <div class="card-body">
                <form id="emailTimelineForm">
                  <div class="mb-2">
                    <input type="email" class="form-control form-control-sm" id="tlEmailInput" placeholder="recipient@example.com" required>
                  </div>
                  <button type="submit" class="btn btn-sm btn-gold w-100" id="tlEmailBtn">
                    <i class="bi bi-send me-1"></i>Send
                  </button>
                </form>
                <div id="tlEmailMsg" class="mt-2" style="display:none;"></div>
              </div>
            </div>

          </div><!-- /summary-card -->
        </div><!-- /col-lg-4 -->

      </div><!-- /row -->
    </div><!-- /p-4 -->

  </main>
</div><!-- /admin-wrapper -->

<!-- Toast -->
<div class="position-fixed bottom-0 end-0 p-3" style="z-index:9999;">
  <div id="tlToast" class="toast align-items-center text-white border-0" role="alert">
    <div class="d-flex">
      <div class="toast-body" id="tlToastBody"></div>
      <button type="button" class="btn-close btn-close-white me-2 m-auto" data-bs-dismiss="toast"></button>
    </div>
  </div>
</div>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
<script>
// Show-more toggle for notes
function toggleNote(id, btn) {
  var el = document.getElementById(id);
  if (!el) return;
  el.classList.toggle('expanded');
  btn.textContent = el.classList.contains('expanded') ? 'Show less' : 'Show more';
}

// Email timeline
document.getElementById('emailTimelineForm').addEventListener('submit', async function(e) {
  e.preventDefault();
  var email = document.getElementById('tlEmailInput').value.trim();
  if (!email) return;
  var btn = document.getElementById('tlEmailBtn');
  btn.disabled = true;
  btn.innerHTML = '<span class="spinner-border spinner-border-sm me-1"></span>Sending…';

  try {
    var res = await fetch('/admin/candidate/<%= candidate.id %>/timeline/email', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ toEmail: email })
    });
    var data = await res.json();
    showToast(data.success ? 'success' : 'danger', data.message);
    if (data.success) document.getElementById('tlEmailInput').value = '';
  } catch (err) {
    showToast('danger', 'Network error. Please try again.');
  } finally {
    btn.disabled = false;
    btn.innerHTML = '<i class="bi bi-send me-1"></i>Send';
  }
});

function showToast(type, msg) {
  var toast = document.getElementById('tlToast');
  var body  = document.getElementById('tlToastBody');
  toast.className = 'toast align-items-center text-white border-0 bg-' + type;
  body.textContent = msg;
  var bsToast = new bootstrap.Toast(toast, { delay: 4000 });
  bsToast.show();
}
</script>
</body>
</html>
