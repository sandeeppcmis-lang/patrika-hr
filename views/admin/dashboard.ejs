<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= title %></title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
  <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css" rel="stylesheet">
  <link href="/css/style.css?v=<%= v %>" rel="stylesheet">
</head>
<body class="admin-page">

  <!-- TOP NAV -->
  <nav class="li-nav">
    <a href="/admin/dashboard" class="li-nav-brand">
      <div class="li-nav-logo">P</div>
      <span class="li-nav-brand-text d-none d-sm-inline">Patrika HR</span>
    </a>
    <form class="li-nav-search" action="/admin/candidates" method="GET">
      <input type="text" name="search" placeholder="Search candidates..." autocomplete="off">
    </form>
    <div class="li-nav-icons">
      <a href="/admin/dashboard" class="li-nav-icon active" title="Dashboard">
        <i class="bi bi-speedometer2"></i><span>Dashboard</span>
      </a>
      <a href="/admin/candidates" class="li-nav-icon" title="Candidates">
        <i class="bi bi-people-fill"></i><span>Candidates</span>
      </a>
      <a href="/admin/positions" class="li-nav-icon" title="Positions">
        <i class="bi bi-briefcase-fill"></i><span>Positions</span>
      </a>
      <a href="/admin/requisitions" class="li-nav-icon" title="Requisitions">
        <i class="bi bi-clipboard-check-fill"></i><span>Requisitions</span>
      </a>
      <a href="/admin/talent-analyst" class="li-nav-icon" title="AI Analyst">
        <i class="bi bi-robot"></i><span>AI Analyst</span>
      </a>
      <a href="/admin/resume-parser" class="li-nav-icon" title="Parser">
        <i class="bi bi-file-earmark-text"></i><span>Parser</span>
      </a>
      <div class="li-nav-divider"></div>
      <div class="li-nav-admin">
        <button class="li-nav-admin-btn" id="adminDropBtn" onclick="toggleAdminDrop()">
          <div class="li-avatar li-avatar-xs"><%= (adminName||'A').charAt(0).toUpperCase() %></div>
          <span style="font-size:.65rem;margin-top:1px;">Me</span>
        </button>
        <div class="li-nav-admin-dropdown" id="adminDropMenu">
          <div style="padding:10px 16px;font-size:.82rem;color:rgba(0,0,0,0.6);">Signed in as<br><strong style="color:rgba(0,0,0,0.9);"><%= adminName %></strong></div>
          <hr>
          <a href="/admin/logout"><i class="bi bi-box-arrow-right me-2"></i>Logout</a>
        </div>
      </div>
    </div>
  </nav>

  <!-- 3-COLUMN LAYOUT -->
  <div class="li-layout">

    <!-- LEFT SIDEBAR -->
    <aside class="li-sidebar-left">
      <div class="li-card">
        <div class="li-card-body" style="text-align:center;padding:20px 16px 12px;">
          <div class="li-avatar mx-auto mb-2" style="width:56px;height:56px;font-size:22px;"><%= (adminName||'A').charAt(0).toUpperCase() %></div>
          <div style="font-weight:700;font-size:.95rem;color:rgba(0,0,0,0.9);"><%= adminName %></div>
          <div style="font-size:.8rem;color:rgba(0,0,0,0.6);">HR Administrator</div>
        </div>
        <hr style="margin:0;border-color:rgba(0,0,0,0.15);">
        <% const sc2 = statusCounts || {}; %>
        <div class="li-stat-row">
          <span style="font-size:.82rem;color:rgba(0,0,0,0.6);">Total Candidates</span>
          <span class="li-stat-num"><%= total %></span>
        </div>
        <div class="li-stat-row">
          <span style="font-size:.82rem;color:rgba(0,0,0,0.6);">Active Positions</span>
          <span class="li-stat-num"><%= typeof activePositions !== 'undefined' ? activePositions : '—' %></span>
        </div>
        <div class="li-stat-row">
          <span style="font-size:.82rem;color:rgba(0,0,0,0.6);">Pending Reqs</span>
          <span class="li-stat-num"><%= typeof pendingRequisitions !== 'undefined' ? pendingRequisitions : '—' %></span>
        </div>
        <hr style="margin:0;border-color:rgba(0,0,0,0.15);">
        <ul class="li-sidebar-nav">
          <li><a href="/admin/dashboard" class="active"><i class="bi bi-speedometer2"></i>Dashboard</a></li>
          <li><a href="/admin/candidates"><i class="bi bi-people-fill"></i>Candidates</a></li>
          <li><a href="/admin/positions"><i class="bi bi-briefcase-fill"></i>Positions</a></li>
          <li><a href="/admin/requisitions"><i class="bi bi-clipboard-check-fill"></i>Requisitions</a></li>
          <li><a href="/admin/talent-analyst"><i class="bi bi-robot"></i>AI Analyst</a></li>
          <li><a href="/admin/resume-parser"><i class="bi bi-file-earmark-text"></i>Resume Parser</a></li>
        </ul>
      </div>
    </aside>

    <!-- MAIN CONTENT -->
    <main class="li-main">
      <%
        const sc = statusCounts || {};
        const shortlisted        = sc['Shortlisted']        || 0;
        const interviewScheduled = sc['Interview Scheduled'] || 0;
        const offerExtended      = sc['Offer Extended']      || 0;
        const hired              = sc['Hired']               || 0;
      %>

      <!-- KPI Grid -->
      <div class="row g-2 mb-3">
        <div class="col-6 col-md-4 col-xl-2">
          <div class="li-kpi">
            <div class="li-card-body">
              <div class="li-avatar" style="background:#0a66c2;width:40px;height:40px;font-size:16px;flex-shrink:0;"><i class="bi bi-people-fill"></i></div>
              <div><div class="kpi-num"><%= total %></div><div class="kpi-label">Total</div></div>
            </div>
          </div>
        </div>
        <div class="col-6 col-md-4 col-xl-2">
          <div class="li-kpi">
            <div class="li-card-body">
              <div class="li-avatar" style="background:#0a66c2;width:40px;height:40px;font-size:16px;flex-shrink:0;"><i class="bi bi-inbox-fill"></i></div>
              <div><div class="kpi-num"><%= newToday %></div><div class="kpi-label">New Today</div></div>
            </div>
          </div>
        </div>
        <div class="col-6 col-md-4 col-xl-2">
          <div class="li-kpi">
            <div class="li-card-body">
              <div class="li-avatar" style="background:#b24020;width:40px;height:40px;font-size:16px;flex-shrink:0;"><i class="bi bi-star-fill"></i></div>
              <div><div class="kpi-num"><%= shortlisted %></div><div class="kpi-label">Shortlisted</div></div>
            </div>
          </div>
        </div>
        <div class="col-6 col-md-4 col-xl-2">
          <div class="li-kpi">
            <div class="li-card-body">
              <div class="li-avatar" style="background:#6f42c1;width:40px;height:40px;font-size:16px;flex-shrink:0;"><i class="bi bi-calendar-check-fill"></i></div>
              <div><div class="kpi-num"><%= interviewScheduled %></div><div class="kpi-label">Interview</div></div>
            </div>
          </div>
        </div>
        <div class="col-6 col-md-4 col-xl-2">
          <div class="li-kpi">
            <div class="li-card-body">
              <div class="li-avatar" style="background:#0e7490;width:40px;height:40px;font-size:16px;flex-shrink:0;"><i class="bi bi-envelope-check-fill"></i></div>
              <div><div class="kpi-num"><%= offerExtended %></div><div class="kpi-label">Offers</div></div>
            </div>
          </div>
        </div>
        <div class="col-6 col-md-4 col-xl-2">
          <div class="li-kpi">
            <div class="li-card-body">
              <div class="li-avatar" style="background:#057642;width:40px;height:40px;font-size:16px;flex-shrink:0;"><i class="bi bi-person-check-fill"></i></div>
              <div><div class="kpi-num"><%= hired %></div><div class="kpi-label">Hired</div></div>
            </div>
          </div>
        </div>
      </div>

      <!-- Charts Row -->
      <div class="row g-2 mb-3">
        <div class="col-lg-7">
          <div class="li-card">
            <div class="li-card-header"><span><i class="bi bi-pie-chart-fill me-2" style="color:#0a66c2;"></i>Status Distribution</span></div>
            <div class="li-card-body d-flex align-items-center justify-content-center" style="min-height:240px;">
              <canvas id="statusChart" style="max-height:220px;"></canvas>
            </div>
          </div>
        </div>
        <div class="col-lg-5">
          <div class="li-card">
            <div class="li-card-header"><span><i class="bi bi-bar-chart-fill me-2" style="color:#0a66c2;"></i>Applicants by Position</span></div>
            <div class="li-card-body p-3" style="overflow-y:auto;max-height:300px;">
              <canvas id="positionChart"></canvas>
            </div>
          </div>
        </div>
      </div>

      <!-- Recent Applications -->
      <div class="li-card">
        <div class="li-card-header">
          <span><i class="bi bi-clock-history me-2" style="color:#0a66c2;"></i>Recent Applications</span>
          <a href="/admin/candidates" class="btn-li-outline" style="font-size:.78rem;padding:3px 12px;">View All</a>
        </div>
        <%
          function timeAgo(d) {
            const diff = (Date.now() - new Date(d)) / 1000;
            if (diff < 60)    return Math.floor(diff) + 's ago';
            if (diff < 3600)  return Math.floor(diff/60) + 'm ago';
            if (diff < 86400) return Math.floor(diff/3600) + 'h ago';
            return Math.floor(diff/86400) + 'd ago';
          }
          const liStatusBadge = {
            'New': 'li-badge-new',
            'Screening': 'li-badge-screening',
            'Shortlisted': 'li-badge-shortlisted',
            'Interview Scheduled': 'li-badge-interview',
            'Offer Extended': 'li-badge-offer',
            'Hired': 'li-badge-hired',
            'Rejected': 'li-badge-rejected'
          };
        %>
        <% if (!recentCandidates || recentCandidates.length === 0) { %>
        <div class="li-card-body text-center" style="color:rgba(0,0,0,0.6);padding:32px;">
          <i class="bi bi-inbox d-block mb-2" style="font-size:2rem;"></i>No candidates yet.
        </div>
        <% } else { %>
        <% recentCandidates.forEach(c => { %>
        <div style="display:flex;align-items:center;gap:12px;padding:12px 16px;border-bottom:1px solid rgba(0,0,0,0.08);cursor:pointer;" onclick="window.location='/admin/candidate/<%= c.id %>'">
          <div class="li-avatar li-avatar-sm"><%= c.fullName.charAt(0).toUpperCase() %></div>
          <div style="flex:1;min-width:0;">
            <div style="font-weight:600;font-size:.88rem;color:rgba(0,0,0,0.9);"><%= c.fullName %></div>
            <div style="font-size:.78rem;color:rgba(0,0,0,0.6);"><%= c.positionApplying %> · <%= timeAgo(c.submittedAt) %></div>
          </div>
          <span class="li-badge <%= liStatusBadge[c.status] || 'li-badge-new' %>"><%= c.status %></span>
          <a href="/admin/candidate/<%= c.id %>" class="btn-li-outline" style="font-size:.75rem;padding:3px 10px;" onclick="event.stopPropagation()">View</a>
        </div>
        <% }) %>
        <% } %>
      </div>
    </main>

    <!-- RIGHT SIDEBAR -->
    <aside class="li-sidebar-right d-none d-xl-block">
      <!-- Quick Actions -->
      <div class="li-card">
        <div class="li-card-header"><span>Quick Actions</span></div>
        <a href="/admin/requisitions" class="li-quick-action"><i class="bi bi-clipboard-plus-fill"></i>New Requisition</a>
        <a href="/admin/candidates/export" class="li-quick-action"><i class="bi bi-file-earmark-excel-fill"></i>Export Excel</a>
        <a href="/admin/resume-parser" class="li-quick-action"><i class="bi bi-file-earmark-text-fill"></i>Resume Parser</a>
        <a href="/admin/talent-analyst" class="li-quick-action"><i class="bi bi-robot"></i>AI Talent Analyst</a>
      </div>

      <!-- Recent Activity -->
      <div class="li-card">
        <div class="li-card-header"><span><i class="bi bi-activity me-2" style="color:#0a66c2;"></i>Recent Activity</span></div>
        <%
          const activityColors = {
            application_received:  '#0a66c2',
            status_changed:        '#b24020',
            note_saved:            '#6c757d',
            email_sent:            '#0e7490',
            whatsapp_sent:         '#057642',
            interview_updated:     '#6f42c1',
            detail_form_submitted: '#057642'
          };
          const activityIcons = {
            application_received:  'bi-inbox-fill',
            status_changed:        'bi-arrow-left-right',
            note_saved:            'bi-journal-text',
            email_sent:            'bi-envelope-fill',
            whatsapp_sent:         'bi-whatsapp',
            interview_updated:     'bi-calendar-event-fill',
            detail_form_submitted: 'bi-person-lines-fill'
          };
          function timeAgoAct(d) {
            const diff = (Date.now() - new Date(d)) / 1000;
            if (diff < 60)    return Math.floor(diff) + 's ago';
            if (diff < 3600)  return Math.floor(diff/60) + 'm ago';
            if (diff < 86400) return Math.floor(diff/3600) + 'h ago';
            return Math.floor(diff/86400) + 'd ago';
          }
        %>
        <% if (!recentActivity || recentActivity.length === 0) { %>
        <div class="li-card-body" style="text-align:center;color:rgba(0,0,0,0.6);padding:24px 16px;">
          <i class="bi bi-clock-history d-block mb-2" style="font-size:1.5rem;"></i>No activity yet.
        </div>
        <% } else { %>
        <% recentActivity.forEach(log => { %>
        <div class="li-activity-item">
          <div class="li-activity-dot" style="background:<%= activityColors[log.activityType]||'#6c757d' %>;margin-top:5px;"></div>
          <div style="flex:1;min-width:0;">
            <div style="font-weight:600;font-size:.8rem;color:rgba(0,0,0,0.9);">
              <i class="bi <%= activityIcons[log.activityType]||'bi-circle' %>" style="color:<%= activityColors[log.activityType]||'#6c757d' %>;margin-right:4px;"></i>
              <%= log.title || log.activityType.replace(/_/g,' ') %>
            </div>
            <% if (log.candidate) { %>
            <div style="font-size:.75rem;color:rgba(0,0,0,0.6);">
              <a href="/admin/candidate/<%= log.candidate.id %>" style="color:rgba(0,0,0,0.6);text-decoration:none;"><%= log.candidate.fullName %></a>
            </div>
            <% } %>
            <div style="font-size:.72rem;color:rgba(0,0,0,0.45);margin-top:2px;"><%= timeAgoAct(log.createdAt) %></div>
          </div>
        </div>
        <% }) %>
        <% } %>
      </div>
    </aside>

  </div>

  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
  <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
  <script>
    function toggleAdminDrop() {
      document.getElementById('adminDropMenu').classList.toggle('show');
    }
    document.addEventListener('click', function(e) {
      if (!e.target.closest('.li-nav-admin')) {
        document.getElementById('adminDropMenu').classList.remove('show');
      }
    });

    const statusCounts = <%- JSON.stringify(statusCounts) %>;
    const statusLabels = Object.keys(statusCounts);
    const statusValues = Object.values(statusCounts);
    const statusPalette = {
      'New': '#94a3b8',
      'Screening': '#0a66c2',
      'Shortlisted': '#b24020',
      'Interview Scheduled': '#6f42c1',
      'Offer Extended': '#0e7490',
      'Hired': '#057642',
      'Rejected': '#cc1016'
    };
    const statusBg = statusLabels.map(l => statusPalette[l] || '#94a3b8');

    new Chart(document.getElementById('statusChart'), {
      type: 'doughnut',
      data: {
        labels: statusLabels,
        datasets: [{ data: statusValues, backgroundColor: statusBg, borderWidth: 2, borderColor: '#fff' }]
      },
      options: {
        cutout: '62%',
        plugins: {
          legend: { position: 'right', labels: { color: 'rgba(0,0,0,0.7)', font: { size: 11 }, padding: 10 } }
        },
        responsive: true,
        maintainAspectRatio: true
      }
    });

    const positionCounts = <%- JSON.stringify(positionCounts) %>;
    const posLabels = positionCounts.map(p => p.position);
    const posValues = positionCounts.map(p => parseInt(p.count));
    const posCanvas = document.getElementById('positionChart');
    posCanvas.height = Math.max(200, posLabels.length * 28);

    new Chart(posCanvas, {
      type: 'bar',
      data: {
        labels: posLabels,
        datasets: [{
          label: 'Applicants',
          data: posValues,
          backgroundColor: 'rgba(10,102,194,0.7)',
          borderColor: '#0a66c2',
          borderWidth: 1,
          borderRadius: 4
        }]
      },
      options: {
        indexAxis: 'y',
        responsive: false,
        maintainAspectRatio: false,
        plugins: { legend: { display: false }, tooltip: { callbacks: {
          label: ctx => ` ${ctx.raw} applicant${ctx.raw !== 1 ? 's' : ''}`
        }}},
        scales: {
          x: { ticks: { color: 'rgba(0,0,0,0.6)', stepSize: 1, precision: 0 }, grid: { color: 'rgba(0,0,0,0.06)' }, min: 0 },
          y: { ticks: { color: 'rgba(0,0,0,0.7)', font: { size: 11 } }, grid: { display: false } }
        }
      }
    });
  </script>
</body>
</html>
