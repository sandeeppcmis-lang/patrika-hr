<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= title %></title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
  <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css" rel="stylesheet">
  <link href="/css/style.css?v=<%= v %>" rel="stylesheet">
  <style>
    .kpi-card { border-radius:12px; padding:20px 18px; color:#fff; display:flex; align-items:center; gap:16px; }
    .kpi-icon { font-size:2rem; opacity:.85; }
    .kpi-value { font-size:2rem; font-weight:700; line-height:1; }
    .kpi-label { font-size:.75rem; opacity:.85; text-transform:uppercase; letter-spacing:.04em; }
    .kpi-trend { font-size:.7rem; margin-top:2px; }
    .activity-dot { width:10px; height:10px; border-radius:50%; flex-shrink:0; margin-top:4px; }
    .recent-row:hover { background: rgba(212,175,55,.06); cursor:pointer; }
    .quick-action-card { border-radius:12px; padding:20px; text-align:center; transition:transform .15s,box-shadow .15s; cursor:pointer; text-decoration:none; color:inherit; display:block; }
    .quick-action-card:hover { transform:translateY(-3px); box-shadow:0 6px 20px rgba(0,0,0,.18); color:inherit; }
    .quick-action-card .qa-icon { font-size:1.8rem; margin-bottom:8px; }
    .quick-action-card .qa-label { font-size:.8rem; font-weight:600; }
  </style>
</head>
<body class="admin-page">

  <div class="admin-wrapper">

    <!-- Sidebar -->
    <nav class="admin-sidebar d-flex flex-column">
      <div class="sidebar-brand">
        <img src="/images/patrika-logo.png" alt="Patrika" class="sidebar-logo"
          onerror="this.style.display='none'">
        <div>
          <div class="fw-bold text-gold">Patrika HR</div>
          <small class="text-white-50">Admin Panel</small>
        </div>
      </div>
      <hr class="border-secondary my-2">
      <ul class="nav flex-column px-2 flex-grow-1">
        <li class="nav-item">
          <a class="nav-link sidebar-link active" href="/admin/dashboard">
            <i class="bi bi-speedometer2 me-2"></i>Dashboard
          </a>
        </li>
        <li class="nav-item">
          <a class="nav-link sidebar-link" href="/admin/candidates">
            <i class="bi bi-people-fill me-2"></i>Candidates
          </a>
        </li>
        <li class="nav-item">
          <a class="nav-link sidebar-link" href="/admin/positions">
            <i class="bi bi-briefcase-fill me-2"></i>Positions
          </a>
        </li>
        <li class="nav-item">
          <a class="nav-link sidebar-link" href="/admin/requisitions">
            <i class="bi bi-clipboard-check-fill me-2"></i>Requisitions
          </a>
        </li>
        <li class="nav-item">
          <a class="nav-link sidebar-link" href="/admin/talent-analyst"><i class="bi bi-robot me-2"></i>Talent Analyst</a>
        </li>
        <li class="nav-item">
          <a class="nav-link sidebar-link" href="/admin/resume-parser">
            <i class="bi bi-file-earmark-text me-2"></i>Resume Parser
          </a>
        </li>
        <li class="nav-item">
          <a class="nav-link sidebar-link" href="/apply" target="_blank">
            <i class="bi bi-file-earmark-person me-2"></i>Application Form
          </a>
        </li>
      </ul>
      <div class="px-2 pb-3">
        <a href="/admin/logout" class="btn btn-outline-light btn-sm w-100">
          <i class="bi bi-box-arrow-right me-1"></i>Logout
        </a>
        <p class="text-white-50 text-center mt-2 mb-0" style="font-size:11px;">
          Logged in as <strong><%= adminName %></strong>
        </p>
      </div>
    </nav>

    <!-- Main Content -->
    <main class="admin-main">

      <!-- Top Bar -->
      <div class="admin-topbar d-flex align-items-center justify-content-between">
        <h5 class="mb-0 fw-bold"><i class="bi bi-speedometer2 me-2 text-gold"></i>Recruitment Dashboard</h5>
        <div class="d-flex gap-2">
          <a href="/apply" target="_blank" class="btn btn-sm btn-outline-gold">
            <i class="bi bi-box-arrow-up-right me-1"></i>View Form
          </a>
          <a href="/admin/candidates" class="btn btn-sm btn-outline-secondary">
            <i class="bi bi-people me-1"></i>All Candidates
          </a>
        </div>
      </div>

      <div class="p-4">

        <%
          // ── KPI helpers ────────────────────────────────────────────────────
          const sc = statusCounts || {};
          const shortlisted        = sc['Shortlisted']        || 0;
          const interviewScheduled = sc['Interview Scheduled'] || 0;
          const offerExtended      = sc['Offer Extended']      || 0;
          const hired              = sc['Hired']               || 0;
        %>

        <!-- KPI Row (6 cards) -->
        <div class="row g-3 mb-4">
          <div class="col-6 col-lg-2">
            <div class="kpi-card" style="background:linear-gradient(135deg,#1a1a2e,#16213e);">
              <div>
                <div class="kpi-icon"><i class="bi bi-people-fill"></i></div>
              </div>
              <div>
                <div class="kpi-value"><%= total %></div>
                <div class="kpi-label">Total Applicants</div>
              </div>
            </div>
          </div>
          <div class="col-6 col-lg-2">
            <div class="kpi-card" style="background:linear-gradient(135deg,#0d6efd,#0a58ca);">
              <div>
                <div class="kpi-icon"><i class="bi bi-inbox-fill"></i></div>
              </div>
              <div>
                <div class="kpi-value"><%= newToday %></div>
                <div class="kpi-label">New Today</div>
                <div class="kpi-trend"><i class="bi bi-arrow-up-short"></i>fresh</div>
              </div>
            </div>
          </div>
          <div class="col-6 col-lg-2">
            <div class="kpi-card" style="background:linear-gradient(135deg,#ffc107,#e0a800);color:#1a1a1a!important;">
              <div>
                <div class="kpi-icon" style="color:#1a1a1a;"><i class="bi bi-star-fill"></i></div>
              </div>
              <div>
                <div class="kpi-value" style="color:#1a1a1a;"><%= shortlisted %></div>
                <div class="kpi-label" style="color:#333;">Shortlisted</div>
              </div>
            </div>
          </div>
          <div class="col-6 col-lg-2">
            <div class="kpi-card" style="background:linear-gradient(135deg,#6f42c1,#5a32a3);">
              <div>
                <div class="kpi-icon"><i class="bi bi-calendar-check-fill"></i></div>
              </div>
              <div>
                <div class="kpi-value"><%= interviewScheduled %></div>
                <div class="kpi-label">Interview</div>
              </div>
            </div>
          </div>
          <div class="col-6 col-lg-2">
            <div class="kpi-card" style="background:linear-gradient(135deg,#fd7e14,#e8680e);">
              <div>
                <div class="kpi-icon"><i class="bi bi-envelope-check-fill"></i></div>
              </div>
              <div>
                <div class="kpi-value"><%= offerExtended %></div>
                <div class="kpi-label">Offer Extended</div>
              </div>
            </div>
          </div>
          <div class="col-6 col-lg-2">
            <div class="kpi-card" style="background:linear-gradient(135deg,#198754,#146c43);">
              <div>
                <div class="kpi-icon"><i class="bi bi-person-check-fill"></i></div>
              </div>
              <div>
                <div class="kpi-value"><%= hired %></div>
                <div class="kpi-label">Hired</div>
                <div class="kpi-trend"><i class="bi bi-arrow-up-short"></i>converted</div>
              </div>
            </div>
          </div>
        </div>

        <!-- Charts Row -->
        <div class="row g-3 mb-4">
          <!-- Doughnut: Status Distribution -->
          <div class="col-lg-7">
            <div class="card shadow-sm h-100">
              <div class="card-header">
                <h6 class="mb-0"><i class="bi bi-pie-chart-fill me-2 text-gold"></i>Status Distribution</h6>
              </div>
              <div class="card-body d-flex align-items-center justify-content-center" style="min-height:260px;">
                <canvas id="statusChart" style="max-height:240px;"></canvas>
              </div>
            </div>
          </div>
          <!-- Bar: All Active Positions -->
          <div class="col-lg-5">
            <div class="card shadow-sm h-100">
              <div class="card-header">
                <h6 class="mb-0"><i class="bi bi-bar-chart-fill me-2 text-gold"></i>Applicants by Position</h6>
              </div>
              <div class="card-body p-3" style="overflow-y:auto;max-height:320px;">
                <canvas id="positionChart"></canvas>
              </div>
            </div>
          </div>
        </div>

        <!-- Recent Applications + Activity Feed -->
        <div class="row g-3 mb-4">
          <!-- Recent Applications (col-lg-8) -->
          <div class="col-lg-8">
            <div class="card shadow-sm">
              <div class="card-header d-flex justify-content-between align-items-center">
                <h6 class="mb-0"><i class="bi bi-clock-history me-2 text-gold"></i>Recent Applications</h6>
                <a href="/admin/candidates" class="btn btn-xs btn-outline-secondary btn-sm">
                  View All <i class="bi bi-arrow-right ms-1"></i>
                </a>
              </div>
              <div class="table-responsive">
                <table class="table table-hover align-middle mb-0" style="font-size:.85rem;">
                  <thead class="table-dark">
                    <tr>
                      <th>Candidate</th>
                      <th>Position</th>
                      <th class="text-center">Grade</th>
                      <th>Status</th>
                      <th>Applied</th>
                    </tr>
                  </thead>
                  <tbody>
                    <% if (!recentCandidates || recentCandidates.length === 0) { %>
                    <tr><td colspan="5" class="text-center text-muted py-4">No candidates yet.</td></tr>
                    <% } %>
                    <%
                      const sColor = { New:'primary', Screening:'info', Shortlisted:'warning', 'Interview Scheduled':'secondary', 'Offer Extended':'dark', Hired:'success', Rejected:'danger' };
                      const gc = { A:'success', B:'primary', C:'warning', D:'danger' };
                    %>
                    <% recentCandidates.forEach(c => { %>
                    <tr class="recent-row" onclick="window.location='/admin/candidate/<%= c.id %>'" style="cursor:pointer;">
                      <td>
                        <div class="d-flex align-items-center gap-2">
                          <div class="avatar-circle" style="width:32px;height:32px;font-size:.8rem;">
                            <%= c.fullName.charAt(0).toUpperCase() %>
                          </div>
                          <div>
                            <div class="fw-semibold" style="font-size:.83rem;"><%= c.fullName %></div>
                            <div class="text-muted" style="font-size:.72rem;"><%= c.email %></div>
                          </div>
                        </div>
                      </td>
                      <td><span class="badge bg-dark" style="font-size:.72rem;"><%= c.positionApplying %></span></td>
                      <td class="text-center">
                        <% if (c.grade) { %>
                        <span class="badge bg-<%= gc[c.grade]||'secondary' %> px-2"><%= c.grade %></span>
                        <% } else { %>
                        <span class="text-muted">—</span>
                        <% } %>
                      </td>
                      <td>
                        <span class="badge bg-<%= sColor[c.status]||'secondary' %>"><%= c.status %></span>
                      </td>
                      <td class="text-muted" style="font-size:.75rem;">
                        <%
                          function timeAgo(d) {
                            const diff = (Date.now() - new Date(d)) / 1000;
                            if (diff < 60)    return Math.floor(diff) + 's ago';
                            if (diff < 3600)  return Math.floor(diff/60) + 'm ago';
                            if (diff < 86400) return Math.floor(diff/3600) + 'h ago';
                            return Math.floor(diff/86400) + 'd ago';
                          }
                        %>
                        <%= timeAgo(c.submittedAt) %>
                      </td>
                    </tr>
                    <% }) %>
                  </tbody>
                </table>
              </div>
            </div>
          </div>

          <!-- Recent Activity Feed (col-lg-4) -->
          <div class="col-lg-4">
            <div class="card shadow-sm h-100">
              <div class="card-header">
                <h6 class="mb-0"><i class="bi bi-activity me-2 text-gold"></i>Recent Activity</h6>
              </div>
              <div class="card-body p-0">
                <%
                  const activityColors = {
                    application_received:   '#0d6efd',
                    status_changed:         '#ffc107',
                    note_saved:             '#6c757d',
                    email_sent:             '#0dcaf0',
                    whatsapp_sent:          '#25d366',
                    interview_updated:      '#6f42c1',
                    detail_form_submitted:  '#198754'
                  };
                  const activityIcons = {
                    application_received:   'bi-inbox-fill',
                    status_changed:         'bi-arrow-left-right',
                    note_saved:             'bi-journal-text',
                    email_sent:             'bi-envelope-fill',
                    whatsapp_sent:          'bi-whatsapp',
                    interview_updated:      'bi-calendar-event-fill',
                    detail_form_submitted:  'bi-person-lines-fill'
                  };
                %>
                <% if (!recentActivity || recentActivity.length === 0) { %>
                <div class="text-center text-muted py-5 px-3">
                  <i class="bi bi-clock-history display-6 d-block mb-2"></i>No activity yet.
                </div>
                <% } else { %>
                <ul class="list-unstyled mb-0" style="font-size:.82rem;">
                  <% recentActivity.forEach((log, idx) => { %>
                  <li class="d-flex gap-3 px-3 py-2 <%= idx < recentActivity.length-1 ? 'border-bottom' : '' %>">
                    <div class="activity-dot mt-1" style="background:<%= activityColors[log.activityType]||'#6c757d' %>;"></div>
                    <div class="flex-grow-1" style="min-width:0;">
                      <div class="d-flex align-items-center gap-1 mb-1">
                        <i class="bi <%= activityIcons[log.activityType]||'bi-circle' %>"
                           style="color:<%= activityColors[log.activityType]||'#6c757d' %>;font-size:.85rem;"></i>
                        <span class="fw-semibold text-truncate"><%= log.title || log.activityType.replace(/_/g,' ') %></span>
                      </div>
                      <% if (log.candidate) { %>
                      <div class="text-muted text-truncate">
                        <a href="/admin/candidate/<%= log.candidate.id %>" class="text-decoration-none text-muted">
                          <i class="bi bi-person me-1"></i><%= log.candidate.fullName %>
                        </a>
                      </div>
                      <% } %>
                      <div class="text-muted" style="font-size:.7rem;">
                        <%
                          function timeAgoAct(d) {
                            const diff = (Date.now() - new Date(d)) / 1000;
                            if (diff < 60)    return Math.floor(diff) + 's ago';
                            if (diff < 3600)  return Math.floor(diff/60) + 'm ago';
                            if (diff < 86400) return Math.floor(diff/3600) + 'h ago';
                            return Math.floor(diff/86400) + 'd ago';
                          }
                        %>
                        <i class="bi bi-clock me-1"></i><%= timeAgoAct(log.createdAt) %>
                      </div>
                    </div>
                  </li>
                  <% }) %>
                </ul>
                <% } %>
              </div>
            </div>
          </div>
        </div>

        <!-- Quick Actions -->
        <div class="card shadow-sm">
          <div class="card-header">
            <h6 class="mb-0"><i class="bi bi-lightning-charge-fill me-2 text-gold"></i>Quick Actions</h6>
          </div>
          <div class="card-body">
            <div class="row g-3">
              <div class="col-6 col-md-3">
                <a href="/admin/requisitions" class="quick-action-card bg-dark text-white">
                  <div class="qa-icon"><i class="bi bi-clipboard-plus-fill text-warning"></i></div>
                  <div class="qa-label">New Requisition</div>
                </a>
              </div>
              <div class="col-6 col-md-3">
                <a href="/admin/resume-parser" class="quick-action-card bg-dark text-white">
                  <div class="qa-icon"><i class="bi bi-file-earmark-text-fill text-info"></i></div>
                  <div class="qa-label">Resume Parser</div>
                </a>
              </div>
              <div class="col-6 col-md-3">
                <a href="/admin/talent-analyst" class="quick-action-card bg-dark text-white">
                  <div class="qa-icon"><i class="bi bi-robot text-success"></i></div>
                  <div class="qa-label">AI Talent Analyst</div>
                </a>
              </div>
              <div class="col-6 col-md-3">
                <a href="/admin/candidates/export" class="quick-action-card bg-dark text-white">
                  <div class="qa-icon"><i class="bi bi-file-earmark-excel-fill text-warning"></i></div>
                  <div class="qa-label">Export Excel</div>
                </a>
              </div>
            </div>
          </div>
        </div>

      </div>
    </main>
  </div>

  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
  <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
  <script>
    // ── Status Doughnut Chart ─────────────────────────────────────────────────
    const statusCounts = <%- JSON.stringify(statusCounts) %>;
    const statusLabels = Object.keys(statusCounts);
    const statusValues = Object.values(statusCounts);
    const statusPalette = {
      'New':                '#0d6efd',
      'Screening':          '#0dcaf0',
      'Shortlisted':        '#ffc107',
      'Interview Scheduled':'#6f42c1',
      'Offer Extended':     '#fd7e14',
      'Hired':              '#198754',
      'Rejected':           '#dc3545'
    };
    const statusBg = statusLabels.map(l => statusPalette[l] || '#6c757d');

    new Chart(document.getElementById('statusChart'), {
      type: 'doughnut',
      data: {
        labels: statusLabels,
        datasets: [{ data: statusValues, backgroundColor: statusBg, borderWidth: 2, borderColor: '#1a1a2e' }]
      },
      options: {
        cutout: '62%',
        plugins: {
          legend: { position: 'right', labels: { color: '#ccc', font: { size: 11 }, padding: 10 } }
        },
        responsive: true,
        maintainAspectRatio: true
      }
    });

    // ── Position Bar Chart ────────────────────────────────────────────────────
    const positionCounts = <%- JSON.stringify(positionCounts) %>;
    const posLabels = positionCounts.map(p => p.position);
    const posValues = positionCounts.map(p => parseInt(p.count));

    // Auto-size height: 28px per bar, min 200px
    const posCanvas = document.getElementById('positionChart');
    posCanvas.height = Math.max(200, posLabels.length * 28);

    new Chart(posCanvas, {
      type: 'bar',
      data: {
        labels: posLabels,
        datasets: [{
          label: 'Applicants',
          data: posValues,
          backgroundColor: posValues.map(v => v > 0 ? 'rgba(212,175,55,.8)' : 'rgba(150,150,150,.3)'),
          borderColor: posValues.map(v => v > 0 ? '#d4af37' : '#888'),
          borderWidth: 1,
          borderRadius: 4
        }]
      },
      options: {
        indexAxis: 'y',
        responsive: false,
        maintainAspectRatio: false,
        plugins: { legend: { display: false }, tooltip: { callbacks: {
          label: ctx => ` ${ctx.raw} applicant${ctx.raw !== 1 ? 's' : ''}`
        }}},
        scales: {
          x: { ticks: { color: '#aaa', stepSize: 1, precision: 0 }, grid: { color: 'rgba(255,255,255,.06)' }, min: 0 },
          y: { ticks: { color: '#ccc', font: { size: 11 } }, grid: { display: false } }
        }
      }
    });
  </script>
</body>
</html>
