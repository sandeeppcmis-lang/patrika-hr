<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= title %></title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
  <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css" rel="stylesheet">
  <link href="/css/style.css?v=<%= v %>" rel="stylesheet">
  <style>
    .df-section { background:#fff; border-radius:10px; box-shadow:0 2px 8px rgba(0,0,0,.07); margin-bottom:20px; }
    .df-title { background:linear-gradient(90deg,#2d2d44,#3d3d5c); color:#f0c030; padding:10px 18px; font-size:.9rem; font-weight:700; border-radius:10px 10px 0 0; }
    .df-body { padding:18px 20px; }
    .df-label { font-size:.73rem; color:#888; font-weight:600; text-transform:uppercase; margin-bottom:2px; }
    .df-value { font-size:.9rem; color:#333; }
    @media print { .no-print { display:none!important; } body { background:#fff; } }
  </style>
</head>
<body class="admin-page">
<div class="admin-wrapper">

  <nav class="admin-sidebar d-flex flex-column">
    <div class="sidebar-brand">
      <img src="/images/patrika-logo.png" alt="Patrika" class="sidebar-logo" onerror="this.style.display='none'">
      <div><div class="fw-bold text-gold">Patrika HR</div><small class="text-white-50">Admin Panel</small></div>
    </div>
    <hr class="border-secondary my-2">
    <ul class="nav flex-column px-2 flex-grow-1">
      <li class="nav-item"><a class="nav-link sidebar-link" href="/admin/dashboard"><i class="bi bi-speedometer2 me-2"></i>Dashboard</a></li>
      <li class="nav-item"><a class="nav-link sidebar-link" href="/admin/candidates"><i class="bi bi-people-fill me-2"></i>Candidates</a></li>
      <li class="nav-item"><a class="nav-link sidebar-link" href="/admin/positions"><i class="bi bi-briefcase-fill me-2"></i>Positions</a></li>
      <li class="nav-item"><a class="nav-link sidebar-link active" href="/admin/requisitions"><i class="bi bi-clipboard-check-fill me-2"></i>Requisitions</a></li>
      <li class="nav-item"><a class="nav-link sidebar-link" href="/admin/talent-analyst"><i class="bi bi-robot me-2"></i>Talent Analyst</a>
        </li>
        <li class="nav-item">
          <a class="nav-link sidebar-link" href="/admin/resume-parser"><i class="bi bi-file-earmark-text me-2"></i>Resume Parser</a></li>
      <li class="nav-item"><a class="nav-link sidebar-link" href="/apply" target="_blank"><i class="bi bi-file-earmark-person me-2"></i>Application Form</a></li>
    </ul>
    <div class="px-2 pb-3">
      <a href="/admin/logout" class="btn btn-outline-light btn-sm w-100"><i class="bi bi-box-arrow-right me-1"></i>Logout</a>
      <p class="text-white-50 text-center mt-2 mb-0" style="font-size:11px;">Logged in as <strong><%= adminName %></strong></p>
    </div>
  </nav>

  <main class="admin-main">
    <div class="admin-topbar d-flex align-items-center justify-content-between no-print">
      <div class="d-flex align-items-center gap-2">
        <a href="/admin/requisitions" class="btn btn-sm btn-outline-secondary"><i class="bi bi-arrow-left"></i></a>
        <h5 class="mb-0 fw-bold"><i class="bi bi-clipboard-check-fill me-2 text-gold"></i>Requisition #<%= r.id %> &ndash; <%= r.positionName %></h5>
      </div>
      <div class="d-flex gap-2">
        <% const sc = {Pending:'warning',Approved:'success',Rejected:'danger','On Hold':'secondary'}; %>
        <span class="badge bg-<%= sc[r.status]||'secondary' %> px-3 py-2" style="font-size:.85rem;"><%= r.status %></span>
        <button class="btn btn-sm btn-outline-secondary" onclick="window.print()"><i class="bi bi-printer me-1"></i>Print</button>
      </div>
    </div>

    <div class="p-4">
      <div class="row g-4">

        <div class="col-lg-8">

          <div class="df-section">
            <div class="df-title">Requisition Header</div>
            <div class="df-body">
              <div class="row g-3">
                <div class="col-md-4"><p class="df-label">Department</p><p class="df-value fw-semibold"><%= r.department %></p></div>
                <div class="col-md-4"><p class="df-label">Requested By</p><p class="df-value"><%= r.requestedByName %></p></div>
                <div class="col-md-4"><p class="df-label">Requested Date</p><p class="df-value"><%= r.requestedDate || '&mdash;' %></p></div>
              </div>
            </div>
          </div>

          <div class="df-section">
            <div class="df-title">Vacancy Details</div>
            <div class="df-body">
              <div class="row g-3">
                <div class="col-md-6"><p class="df-label">Position</p><p class="df-value fw-semibold fs-6"><%= r.positionName %></p></div>
                <div class="col-md-3"><p class="df-label">No. of Requirements</p><p class="df-value"><%= r.noOfRequirements %></p></div>
                <div class="col-md-3"><p class="df-label">Present Strength</p><p class="df-value"><%= r.presentStrength != null ? r.presentStrength : '&mdash;' %></p></div>
                <div class="col-md-4">
                  <p class="df-label">Recruitment Type</p>
                  <% const tc = {'New Recruitment':'primary','Replacement':'warning','Expansion':'info'}; %>
                  <span class="badge bg-<%= tc[r.recruitmentType]||'secondary' %> px-3 py-2"><%= r.recruitmentType %></span>
                </div>
                <% if (r.whyRequired) { %>
                <div class="col-12"><p class="df-label">Why Additional Manpower Required</p><p class="df-value" style="white-space:pre-wrap;"><%= r.whyRequired %></p></div>
                <% } %>
                <% if (r.reasonIfNew) { %>
                <div class="col-12"><p class="df-label">Reason (New Appointment)</p><p class="df-value"><%= r.reasonIfNew %></p></div>
                <% } %>
                <% if (r.recruitmentType === 'Replacement') { %>
                <div class="col-12">
                  <div class="p-3 bg-warning bg-opacity-10 border border-warning rounded">
                    <p class="df-label mb-2">Replacement Details</p>
                    <div class="row g-2">
                      <div class="col-md-4"><p class="df-label">Name</p><p class="df-value"><%= r.replacementName || '&mdash;' %></p></div>
                      <div class="col-md-4"><p class="df-label">Salary</p><p class="df-value"><%= r.replacementSalary || '&mdash;' %></p></div>
                      <div class="col-md-4"><p class="df-label">Last Working Date</p><p class="df-value"><%= r.replacementLastWorking || '&mdash;' %></p></div>
                    </div>
                  </div>
                </div>
                <% } %>
                <% if (r.jobResponsibility) { %>
                <div class="col-12"><p class="df-label">Job Responsibility</p><p class="df-value" style="white-space:pre-wrap;"><%= r.jobResponsibility %></p></div>
                <% } %>
              </div>
            </div>
          </div>

          <div class="df-section">
            <div class="df-title">Job Specification</div>
            <div class="df-body">
              <div class="row g-3">
                <div class="col-md-4"><p class="df-label">Age</p><p class="df-value"><%= r.ageSpec || '&mdash;' %></p></div>
                <div class="col-md-4"><p class="df-label">Qualification</p><p class="df-value"><%= r.qualificationSpec || '&mdash;' %></p></div>
                <div class="col-md-4"><p class="df-label">Experience</p><p class="df-value"><%= r.experienceSpec || '&mdash;' %></p></div>
                <div class="col-md-4"><p class="df-label">Gender</p><p class="df-value"><%= r.genderSpec || '&mdash;' %></p></div>
                <div class="col-md-4"><p class="df-label">Other Skills (IT etc.)</p><p class="df-value"><%= r.otherSkills || '&mdash;' %></p></div>
                <div class="col-md-4"><p class="df-label">Place of Posting</p><p class="df-value"><%= r.placeOfPosting || '&mdash;' %></p></div>
                <div class="col-md-4"><p class="df-label">Salary Range</p><p class="df-value"><%= r.salaryRange || '&mdash;' %></p></div>
                <div class="col-md-4"><p class="df-label">Reporting To</p><p class="df-value"><%= r.reportingTo || '&mdash;' %></p></div>
              </div>
            </div>
          </div>

          <% if (r.referralName || r.referralMobile || r.referralEmail) { %>
          <div class="df-section">
            <div class="df-title">Referral for the Job</div>
            <div class="df-body">
              <div class="row g-3">
                <div class="col-md-4"><p class="df-label">Name</p><p class="df-value"><%= r.referralName || '&mdash;' %></p></div>
                <div class="col-md-4"><p class="df-label">Mobile</p><p class="df-value"><%= r.referralMobile || '&mdash;' %></p></div>
                <div class="col-md-4"><p class="df-label">Email</p><p class="df-value"><%= r.referralEmail || '&mdash;' %></p></div>
              </div>
            </div>
          </div>
          <% } %>

        </div>

        <div class="col-lg-4 no-print">
          <div class="df-section sticky-top" style="top:80px;">
            <div class="df-title">HR Action</div>
            <div class="df-body">
              <div class="mb-3">
                <p class="df-label">Submitted</p>
                <p class="df-value small"><%= new Date(r.createdAt).toLocaleDateString('en-IN',{day:'numeric',month:'short',year:'numeric'}) %></p>
              </div>
              <hr>
              <div class="mb-3">
                <label class="form-label fw-semibold" style="font-size:.85rem;">Update Status</label>
                <select class="form-select form-select-sm" id="statusSelect">
                  <% ['Pending','Approved','Rejected','On Hold'].forEach(function(s){ %>
                  <option value="<%= s %>" <%= r.status === s ? 'selected' : '' %>><%= s %></option>
                  <% }); %>
                </select>
              </div>
              <div class="mb-3">
                <label class="form-label fw-semibold" style="font-size:.85rem;">HR Notes</label>
                <textarea class="form-control form-control-sm" id="adminNotes" rows="5" placeholder="Add notes..."><%= r.adminNotes || '' %></textarea>
              </div>
              <button class="btn btn-gold btn-sm w-100" onclick="saveStatus()">
                <i class="bi bi-save me-1"></i>Save Status
              </button>
              <div id="saveResult" class="mt-2"></div>
            </div>
          </div>
        </div>

      </div>
    </div>
  </main>
</div>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
<script>
  async function saveStatus() {
    const btn = document.querySelector('[onclick="saveStatus()"]');
    btn.disabled = true;
    btn.innerHTML = '<span class="spinner-border spinner-border-sm me-1"></span>Saving...';
    try {
      const resp = await fetch('/admin/requisitions/<%= r.id %>/status', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({
          status:     document.getElementById('statusSelect').value,
          adminNotes: document.getElementById('adminNotes').value
        })
      });
      const d = await resp.json();
      const el = document.getElementById('saveResult');
      if (d.success) {
        el.innerHTML = '<div class="alert alert-success py-2 small mb-0"><i class="bi bi-check-circle me-1"></i>Saved</div>';
        setTimeout(function(){ location.reload(); }, 800);
      } else {
        el.innerHTML = '<div class="alert alert-danger py-2 small mb-0">' + (d.error || 'Error') + '</div>';
        btn.disabled = false;
        btn.innerHTML = '<i class="bi bi-save me-1"></i>Save Status';
      }
    } catch(e) {
      document.getElementById('saveResult').innerHTML = '<div class="alert alert-danger py-2 small mb-0">Network error</div>';
      btn.disabled = false;
      btn.innerHTML = '<i class="bi bi-save me-1"></i>Save Status';
    }
  }
</script>
</body>
</html>
