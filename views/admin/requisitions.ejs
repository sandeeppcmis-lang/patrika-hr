<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= title %></title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
  <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css" rel="stylesheet">
  <link href="/css/style.css?v=<%= v %>" rel="stylesheet">
  <style>
    .req-table td { vertical-align: middle; font-size: .875rem; }
    .req-table th { font-size: .8rem; font-weight: 600; text-transform: uppercase; letter-spacing: .04em; }
    .stat-card { border-radius: 10px; padding: 18px 20px; color: #fff; }
    .filter-bar { background: #fff; border: 1px solid #e8dfc5; border-radius: 8px; padding: 16px 20px; }
    .btn-outline-gold { border-color: #c9941a; color: #c9941a; }
    .btn-outline-gold:hover { background: #c9941a; color: #fff; }
    .text-gold { color: #f0c030 !important; }
  </style>
</head>
<body class="admin-page">

  <!-- TOP NAV -->
  <nav class="li-nav">
    <a href="/admin/dashboard" class="li-nav-brand">
      <div class="li-nav-logo">P</div>
      <span class="li-nav-brand-text d-none d-sm-inline">Patrika HR</span>
    </a>
    <form class="li-nav-search" action="/admin/candidates" method="GET">
      <input type="text" name="search" placeholder="Search candidates..." autocomplete="off">
    </form>
    <div class="li-nav-icons">
      <a href="/admin/dashboard" class="li-nav-icon" title="Dashboard">
        <i class="bi bi-speedometer2"></i><span>Dashboard</span>
      </a>
      <a href="/admin/candidates" class="li-nav-icon" title="Candidates">
        <i class="bi bi-people-fill"></i><span>Candidates</span>
      </a>
      <a href="/admin/positions" class="li-nav-icon" title="Positions">
        <i class="bi bi-briefcase-fill"></i><span>Positions</span>
      </a>
      <a href="/admin/requisitions" class="li-nav-icon active" title="Requisitions">
        <i class="bi bi-clipboard-check-fill"></i><span>Requisitions</span>
      </a>
      <a href="/admin/talent-analyst" class="li-nav-icon" title="AI Analyst">
        <i class="bi bi-robot"></i><span>AI Analyst</span>
      </a>
      <a href="/admin/resume-parser" class="li-nav-icon" title="Parser">
        <i class="bi bi-file-earmark-text"></i><span>Parser</span>
      </a>
      <div class="li-nav-divider"></div>
      <div class="li-nav-admin">
        <button class="li-nav-admin-btn" id="adminDropBtn" onclick="toggleAdminDrop()">
          <div class="li-avatar li-avatar-xs"><%= (adminName||'A').charAt(0).toUpperCase() %></div>
          <span style="font-size:.65rem;margin-top:1px;">Me</span>
        </button>
        <div class="li-nav-admin-dropdown" id="adminDropMenu">
          <div style="padding:10px 16px;font-size:.82rem;color:rgba(0,0,0,0.6);">Signed in as<br><strong style="color:rgba(0,0,0,0.9);"><%= adminName %></strong></div>
          <hr>
          <a href="/admin/logout"><i class="bi bi-box-arrow-right me-2"></i>Logout</a>
        </div>
      </div>
    </div>
  </nav>

  <div class="li-layout">

    <!-- LEFT SIDEBAR -->
    <aside class="li-sidebar-left">
      <div class="li-card">
        <div class="li-card-body" style="text-align:center;padding:20px 16px 12px;">
          <div class="li-avatar mx-auto mb-2" style="width:56px;height:56px;font-size:22px;"><%= (adminName||'A').charAt(0).toUpperCase() %></div>
          <div style="font-weight:700;font-size:.95rem;color:rgba(0,0,0,0.9);"><%= adminName %></div>
          <div style="font-size:.8rem;color:rgba(0,0,0,0.6);">HR Administrator</div>
        </div>
        <hr style="margin:0;border-color:rgba(0,0,0,0.15);">
        <ul class="li-sidebar-nav">
          <li><a href="/admin/dashboard"><i class="bi bi-speedometer2"></i>Dashboard</a></li>
          <li><a href="/admin/candidates"><i class="bi bi-people-fill"></i>Candidates</a></li>
          <li><a href="/admin/positions"><i class="bi bi-briefcase-fill"></i>Positions</a></li>
          <li><a href="/admin/requisitions" class="active"><i class="bi bi-clipboard-check-fill"></i>Requisitions</a></li>
          <li><a href="/admin/talent-analyst"><i class="bi bi-robot"></i>AI Analyst</a></li>
          <li><a href="/admin/resume-parser"><i class="bi bi-file-earmark-text"></i>Resume Parser</a></li>
        </ul>
      </div>
    </aside>

    <main class="li-main">
      <div class="li-page-header">
        <div>
          <div class="li-page-title"><i class="bi bi-clipboard-check-fill me-2" style="color:#0a66c2;"></i>Manpower Requisitions</div>
          <small style="color:rgba(0,0,0,0.6);">Review and manage department requisitions</small>
        </div>
        <div class="d-flex gap-2">
          <button class="btn-li-outline" data-bs-toggle="modal" data-bs-target="#sendFormModal" style="font-size:.8rem;">
            <i class="bi bi-envelope-fill me-1"></i>Send Form via Email
          </button>
          <a href="/requisition" target="_blank" class="btn-li-primary" style="font-size:.8rem;">
            <i class="bi bi-plus-lg me-1"></i>New Requisition
          </a>
        </div>
      </div>

      <!-- Stats Row -->
      <div class="row g-3 mb-4">
        <div class="col-6 col-md-3">
          <div class="stat-card" style="background:linear-gradient(135deg,#1a1a2e,#3a2a00);">
            <div style="font-size:2rem;font-weight:700;color:#f0c030;"><%= stats.total %></div>
            <div style="font-size:.8rem;color:rgba(255,255,255,.7);">Total Requisitions</div>
          </div>
        </div>
        <div class="col-6 col-md-3">
          <div class="stat-card" style="background:linear-gradient(135deg,#6f4e00,#c9941a);">
            <div style="font-size:2rem;font-weight:700;"><%= stats.pending %></div>
            <div style="font-size:.8rem;color:rgba(255,255,255,.85);">Pending</div>
          </div>
        </div>
        <div class="col-6 col-md-3">
          <div class="stat-card" style="background:linear-gradient(135deg,#155724,#1e7e34);">
            <div style="font-size:2rem;font-weight:700;"><%= stats.approved %></div>
            <div style="font-size:.8rem;color:rgba(255,255,255,.85);">Approved</div>
          </div>
        </div>
        <div class="col-6 col-md-3">
          <div class="stat-card" style="background:linear-gradient(135deg,#721c24,#b02a37);">
            <div style="font-size:2rem;font-weight:700;"><%= stats.rejected %></div>
            <div style="font-size:.8rem;color:rgba(255,255,255,.85);">Rejected</div>
          </div>
        </div>
      </div>

      <!-- Filter Bar -->
      <div class="filter-bar mb-4">
        <form method="GET" action="/admin/requisitions" class="row g-2 align-items-end">
          <div class="col-md-4">
            <label class="form-label mb-1" style="font-size:.8rem;font-weight:600;">Filter by Status</label>
            <select name="status" class="form-select form-select-sm">
              <option value="All" <%- filterStatus === 'All' ? 'selected' : '' %>>All Statuses</option>
              <option value="Pending"   <%- filterStatus === 'Pending'   ? 'selected' : '' %>>Pending</option>
              <option value="Approved"  <%- filterStatus === 'Approved'  ? 'selected' : '' %>>Approved</option>
              <option value="Rejected"  <%- filterStatus === 'Rejected'  ? 'selected' : '' %>>Rejected</option>
              <option value="On Hold"   <%- filterStatus === 'On Hold'   ? 'selected' : '' %>>On Hold</option>
            </select>
          </div>
          <div class="col-md-4">
            <label class="form-label mb-1" style="font-size:.8rem;font-weight:600;">Search Department</label>
            <input type="text" name="department" class="form-control form-control-sm"
                   placeholder="Department name..." value="<%= filterDept %>">
          </div>
          <div class="col-md-4 d-flex gap-2">
            <button type="submit" class="btn btn-gold btn-sm">
              <i class="bi bi-search me-1"></i>Filter
            </button>
            <a href="/admin/requisitions" class="btn btn-outline-secondary btn-sm">
              <i class="bi bi-x-lg me-1"></i>Clear
            </a>
          </div>
        </form>
      </div>

      <!-- Table -->
      <div class="card">
        <div class="card-body p-0">
          <% if (requisitions.length === 0) { %>
            <div class="text-center py-5 text-muted">
              <i class="bi bi-clipboard-x" style="font-size:3rem;opacity:.3;"></i>
              <p class="mt-3">No requisitions found.</p>
            </div>
          <% } else { %>
          <div class="table-responsive">
            <table class="table table-hover req-table mb-0">
              <thead class="table-dark">
                <tr>
                  <th>#</th>
                  <th>Department</th>
                  <th>Position</th>
                  <th>Type</th>
                  <th>Req.</th>
                  <th>Requested By</th>
                  <th>Date</th>
                  <th>Status</th>
                  <th>Action</th>
                </tr>
              </thead>
              <tbody>
                <% requisitions.forEach((r, idx) => { %>
                <tr style="cursor:pointer;" onclick="window.location='/admin/requisitions/<%= r.id %>'">
                  <td class="text-muted"><%= idx + 1 %></td>
                  <td><span class="fw-semibold"><%= r.department %></span></td>
                  <td><%= r.positionName %></td>
                  <td>
                    <% if (r.recruitmentType === 'New Recruitment') { %>
                      <span class="badge bg-primary"><%= r.recruitmentType %></span>
                    <% } else if (r.recruitmentType === 'Replacement') { %>
                      <span class="badge bg-warning text-dark"><%= r.recruitmentType %></span>
                    <% } else { %>
                      <span class="badge bg-info text-dark"><%= r.recruitmentType %></span>
                    <% } %>
                  </td>
                  <td class="text-center"><strong><%= r.noOfRequirements %></strong></td>
                  <td><%= r.requestedByName %></td>
                  <td class="text-muted"><%= r.requestedDate || (r.createdAt ? new Date(r.createdAt).toLocaleDateString('en-IN') : '—') %></td>
                  <td>
                    <% if (r.status === 'Pending') { %>
                      <span class="badge bg-warning text-dark">Pending</span>
                    <% } else if (r.status === 'Approved') { %>
                      <span class="badge bg-success">Approved</span>
                    <% } else if (r.status === 'Rejected') { %>
                      <span class="badge bg-danger">Rejected</span>
                    <% } else { %>
                      <span class="badge bg-secondary">On Hold</span>
                    <% } %>
                  </td>
                  <td onclick="event.stopPropagation()">
                    <a href="/admin/requisitions/<%= r.id %>" class="btn btn-outline-secondary btn-sm">
                      <i class="bi bi-eye-fill"></i> View
                    </a>
                  </td>
                </tr>
                <% }) %>
              </tbody>
            </table>
          </div>
          <% } %>
        </div>
      </div>
    </main>
  </div>

<!-- Send Form Modal -->
<div class="modal fade" id="sendFormModal" tabindex="-1" aria-labelledby="sendFormModalLabel" aria-hidden="true">
  <div class="modal-dialog">
    <div class="modal-content">
      <div class="modal-header" style="background:linear-gradient(90deg,#1a1a2e,#3a2a00);">
        <h5 class="modal-title text-gold" id="sendFormModalLabel">
          <i class="bi bi-envelope-fill me-2"></i>Send Requisition Form via Email
        </h5>
        <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
      </div>
      <div class="modal-body p-4">
        <p class="text-muted small mb-3">A personalised form link will be emailed to the department head. Once they fill and submit it, the data will be saved automatically.</p>
        <div class="mb-3">
          <label class="form-label fw-semibold" style="font-size:.85rem;">Department Head Name <span class="text-danger">*</span></label>
          <input type="text" class="form-control form-control-sm" id="sf_name" placeholder="e.g. Ramesh Sharma">
        </div>
        <div class="mb-3">
          <label class="form-label fw-semibold" style="font-size:.85rem;">Email Address <span class="text-danger">*</span></label>
          <input type="email" class="form-control form-control-sm" id="sf_email" placeholder="dept.head@patrika.com">
        </div>
        <div class="mb-3">
          <label class="form-label fw-semibold" style="font-size:.85rem;">Department (optional pre-fill)</label>
          <input type="text" class="form-control form-control-sm" id="sf_dept" placeholder="e.g. Sales & Marketing">
        </div>
        <div id="sf_result"></div>
      </div>
      <div class="modal-footer">
        <button type="button" class="btn btn-secondary btn-sm" data-bs-dismiss="modal">Cancel</button>
        <button type="button" class="btn btn-gold btn-sm" id="sf_sendBtn" onclick="sendReqForm()">
          <i class="bi bi-send-fill me-1"></i>Send Form Link
        </button>
      </div>
    </div>
  </div>
</div>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
<script>
  function toggleAdminDrop() {
    document.getElementById('adminDropMenu').classList.toggle('show');
  }
  document.addEventListener('click', function(e) {
    if (!e.target.closest('.li-nav-admin')) {
      document.getElementById('adminDropMenu').classList.remove('show');
    }
  });

  async function sendReqForm() {
    const name  = document.getElementById('sf_name').value.trim();
    const email = document.getElementById('sf_email').value.trim();
    const dept  = document.getElementById('sf_dept').value.trim();
    const res   = document.getElementById('sf_result');

    if (!email) { res.innerHTML = '<div class="alert alert-warning py-2 small mb-0">Please enter an email address.</div>'; return; }

    const btn = document.getElementById('sf_sendBtn');
    btn.disabled = true;
    btn.innerHTML = '<span class="spinner-border spinner-border-sm me-1"></span>Sending...';
    res.innerHTML = '';

    try {
      const r = await fetch('/admin/requisitions/send-form', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ sentToName: name, sentToEmail: email, department: dept })
      });
      const d = await r.json();
      if (d.success) {
        res.innerHTML = '<div class="alert alert-success py-2 small mb-0"><i class="bi bi-check-circle me-1"></i>Form link sent to <strong>' + email + '</strong>. The requisition will appear here once submitted.</div>';
        btn.innerHTML = '<i class="bi bi-check-lg me-1"></i>Sent!';
        setTimeout(() => location.reload(), 2000);
      } else {
        res.innerHTML = '<div class="alert alert-danger py-2 small mb-0">' + (d.error || 'Failed to send') + '</div>';
        btn.disabled = false;
        btn.innerHTML = '<i class="bi bi-send-fill me-1"></i>Send Form Link';
      }
    } catch(e) {
      res.innerHTML = '<div class="alert alert-danger py-2 small mb-0">Network error: ' + e.message + '</div>';
      btn.disabled = false;
      btn.innerHTML = '<i class="bi bi-send-fill me-1"></i>Send Form Link';
    }
  }

  // Reset modal state on close
  document.getElementById('sendFormModal').addEventListener('hidden.bs.modal', function() {
    document.getElementById('sf_name').value = '';
    document.getElementById('sf_email').value = '';
    document.getElementById('sf_dept').value = '';
    document.getElementById('sf_result').innerHTML = '';
    const btn = document.getElementById('sf_sendBtn');
    btn.disabled = false;
    btn.innerHTML = '<i class="bi bi-send-fill me-1"></i>Send Form Link';
  });
</script>
</body>
</html>
