      const jd = JOB_DESCRIPTIONS[this.value];
      const panel   = document.getElementById('jdPanel');
      const title   = document.getElementById('jdTitle');
      const badge   = document.getElementById('jdBadge');
      const content = document.getElementById('jdContent');
      if (jd) {
        title.textContent   = this.value;
        badge.textContent   = jd.badge;
        content.innerHTML   = jd.html;
        panel.classList.remove('d-none');
        panel.scrollIntoView({ behavior: 'smooth', block: 'nearest' });
      } else {
        panel.classList.add('d-none');
      }
    });
  });
